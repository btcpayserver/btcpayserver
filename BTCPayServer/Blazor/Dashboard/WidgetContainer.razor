@using BTCPayServer.Blazor.Dashboard.Models
@using Newtonsoft.Json.Linq

<div class="widget @(Descriptor.CssClass ?? "")" @ref="_widgetElement">
    @if (EditMode)
    {
        <div class="widget-edit-header">
            <div class="widget-drag-handle">
                <span class="widget-grip-dots"></span>
                <span class="small">@Descriptor.Name</span>
            </div>
            <div class="widget-controls">
                <button class="widget-control-btn" title="Configure widget"
                        @onclick="() => OnConfigure.InvokeAsync()">
                    <svg role="img" class="icon icon-settings"><use href="/img/icon-sprite.svg#settings"></use></svg>
                </button>
                <button class="widget-control-btn widget-control-btn--danger" title="Remove widget"
                        @onclick="OnRemove">
                    <svg role="img" class="icon icon-cross"><use href="/img/icon-sprite.svg#cross"></use></svg>
                </button>
            </div>
        </div>
    }
    <ErrorBoundary @ref="_errorBoundary">
        <ChildContent>
            <DynamicComponent @key="Placement.Id"
                              Type="@Descriptor.ComponentType"
                              Parameters="@GetWidgetParameters()" />
        </ChildContent>
        <ErrorContent Context="ex">
            <div class="text-danger small p-2">
                <strong>Widget error</strong>
                <p class="mb-0">@ex.Message</p>
                <button class="btn btn-link btn-sm p-0 mt-1" @onclick="RecoverFromError">Retry</button>
            </div>
        </ErrorContent>
    </ErrorBoundary>
</div>

@if (EditMode)
{
    <div class="widget-resize-right"></div>
    <div class="widget-resize-bottom"></div>
}

@code {
    [Parameter] public WidgetPlacement Placement { get; set; } = null!;
    [Parameter] public WidgetDescriptor Descriptor { get; set; } = null!;
    [Parameter] public string StoreId { get; set; } = string.Empty;
    [Parameter] public string UserId { get; set; } = string.Empty;
    [Parameter] public bool EditMode { get; set; }
    [Parameter] public bool WidgetEditMode { get; set; }
    [Parameter] public EventCallback<JObject> OnConfigChanged { get; set; }
    [Parameter] public EventCallback<bool> OnEditModeChanged { get; set; }
    [Parameter] public EventCallback OnRemove { get; set; }
    [Parameter] public EventCallback<(int cols, int rows)> OnSizeChanged { get; set; }
    [Parameter] public EventCallback OnConfigure { get; set; }

    [Inject] DashboardJsInterop JsInterop { get; set; } = null!;

    private ErrorBoundary? _errorBoundary;
    private ElementReference _widgetElement;
    private DotNetObjectReference<object>? _resizeRef;
    private int _lastInitCol;
    private int _lastInitRow;
    private bool _resizeInitialized;

    private Dictionary<string, object> GetWidgetParameters()
    {
        return new Dictionary<string, object>
        {
            { "StoreId", StoreId },
            { "UserId", UserId },
            { "Readonly", Descriptor.AlwaysInteractive ? false : (!EditMode || WidgetEditMode) },
            { "Size", Placement.ColumnSize },
            { "Config", Placement.Config! },
            { "RequiredPermissions", Descriptor.RequiredPermissions },
            { "ConfigChanged", EventCallback.Factory.Create<JObject>(this, config => OnConfigChanged.InvokeAsync(config)) },
            { "EditModeChanged", EventCallback.Factory.Create<bool>(this, editing => OnEditModeChanged.InvokeAsync(editing)) },
            { "OnRemove", EventCallback.Factory.Create(this, () => OnRemove.InvokeAsync()) },
            { "RequestConfigure", EventCallback.Factory.Create(this, () => OnConfigure.InvokeAsync()) }
        };
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (EditMode)
        {
            // Only re-init resize handlers when size actually changed or first time
            if (!_resizeInitialized || _lastInitCol != Placement.ColumnSize || _lastInitRow != Placement.RowSpan)
            {
                _resizeRef ??= DotNetObjectReference.Create<object>(this);
                _lastInitCol = Placement.ColumnSize;
                _lastInitRow = Placement.RowSpan;
                _resizeInitialized = true;
                await JsInterop.InitResize(_widgetElement, Placement.Id,
                    Placement.ColumnSize, Descriptor.MinColumnSize, Descriptor.MaxColumnSize,
                    Placement.RowSpan, Descriptor.MinRowSpan, Descriptor.MaxRowSpan,
                    _resizeRef);
            }
        }
        else
        {
            _resizeInitialized = false;
        }
    }

    [JSInvokable]
    public async Task OnWidgetResized(string placementId, int newColSize, int newRowSpan)
    {
        if (placementId != Placement.Id) return;
        Placement.ColumnSize = newColSize;
        Placement.RowSpan = newRowSpan;
        await OnSizeChanged.InvokeAsync((newColSize, newRowSpan));
        await InvokeAsync(StateHasChanged);
    }

    private void RecoverFromError()
    {
        _errorBoundary?.Recover();
    }
}

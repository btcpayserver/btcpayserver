@using BTCPayServer.Blazor.Dashboard
@using BTCPayServer.Blazor.Dashboard.Models
@using BTCPayServer.Client
@inherits BTCPayServer.Blazor.Dashboard.BaseWidgetComponent<AppSalesWidget.AppSalesConfig>

@if (!HasAccess)
{
    <div class="widget-body p-3">
        <h6 class="text-muted">App Sales</h6>
        <p class="text-secondary small">@(AccessDeniedMessage ?? "You do not have permission to view this widget.")</p>
    </div>
}
else if (Loading)
{
    <div class="widget-body p-3">
        <h6 class="text-muted">App Sales</h6>
        <div class="d-flex justify-content-center p-3">
            <div class="spinner-border text-light" role="status">
                <span class="visually-hidden">Loading...</span>
            </div>
        </div>
    </div>
}
else if (_error is not null)
{
    <div class="widget-body p-3">
        <h6 class="text-muted">App Sales</h6>
        <p class="text-danger small">@_error</p>
    </div>
}
else
{
    var config = TypedConfig ?? new AppSalesConfig();
    <div class="widget-body p-3">
        <h6 class="mb-3">App Sales</h6>
        @if (!string.IsNullOrEmpty(config.AppId))
        {
            <p class="text-muted small mb-0">Sales data for app: <strong>@config.AppId</strong></p>
            @if (Size > 6)
            {
                <p class="text-secondary small fst-italic mt-2 mb-0">
                    Sales chart and totals will be displayed here once app data integration is complete.
                </p>
            }
        }
        else
        {
            <p class="text-muted small mb-0">No app configured. Edit this widget to select an app.</p>
        }
    </div>
}

@code {
    public static readonly WidgetDescriptor Descriptor = new()
    {
        Type = "AppSales",
        Name = "App Sales",
        Description = "Displays sales data for a specific app",
        Category = "Apps",
        ComponentType = typeof(AppSalesWidget),
        Scope = WidgetScope.Store,
        DefaultColumnSize = 6
    };

    public class AppSalesConfig
    {
        public string AppId { get; set; } = "";
    }

    private string? _error;

    protected override Task OnParametersSetAsync()
    {
        if (string.IsNullOrEmpty(StoreId))
            return Task.CompletedTask;

        // App sales data fetching will be implemented in a future iteration.
        Loading = false;
        return Task.CompletedTask;
    }
}

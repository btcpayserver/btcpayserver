@using BTCPayServer.Blazor.Dashboard
@using BTCPayServer.Blazor.Dashboard.Models
@using BTCPayServer.Client
@using BTCPayServer.Client.Models
@using BTCPayServer.Services.Apps
@inherits BTCPayServer.Blazor.Dashboard.BaseWidgetComponent<AppTopItemsWidget.AppTopItemsConfig>

@inject AppService AppService

@if (!HasAccess)
{
    <div class="widget-body p-3">
        <h6 class="text-muted">App Top Items</h6>
        <p class="text-secondary small">@(AccessDeniedMessage ?? "You do not have permission to view this widget.")</p>
    </div>
}
else if (Loading)
{
    <div class="widget-body p-3">
        <h6 class="text-muted">App Top Items</h6>
        <div class="d-flex justify-content-center p-3">
            <div class="spinner-border text-light" role="status">
                <span class="visually-hidden">Loading...</span>
            </div>
        </div>
    </div>
}
else if (_error is not null)
{
    <div class="widget-body p-3">
        <h6 class="text-muted">App Top Items</h6>
        <p class="text-danger small">@_error</p>
    </div>
}
else
{
    var config = TypedConfig ?? new AppTopItemsConfig();
    <div class="widget-body p-3">
        @if (string.IsNullOrEmpty(config.AppId))
        {
            <h6 class="text-muted">App Top Items</h6>
            <p class="text-muted small mb-0">No app configured. Edit this widget to select an app.</p>
        }
        else
        {
            <h6 class="mb-3">@(_appName ?? "App Top Items")</h6>

            @if (_entries is null || _entries.Count == 0)
            {
                <p class="text-muted small mb-0">No item data yet.</p>
            }
            else if (Size > 6)
            {
                <div class="table-responsive">
                    <table class="table table-sm table-hover mb-0">
                        <thead>
                            <tr>
                                <th>Item</th>
                                <th class="text-end">Sales</th>
                                <th class="text-end">Total</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var entry in _entries)
                            {
                                <tr>
                                    <td class="small">@(entry.Title ?? entry.ItemCode)</td>
                                    <td class="text-end small">@entry.SalesCount</td>
                                    <td class="text-end small">@entry.TotalFormatted</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                @foreach (var entry in _entries.Take(3))
                {
                    <div class="d-flex justify-content-between mb-1">
                        <span class="small text-truncate">@(entry.Title ?? entry.ItemCode)</span>
                        <span class="small text-muted">@entry.SalesCount sales</span>
                    </div>
                }
                @if (_entries.Count > 3)
                {
                    <p class="text-muted small mb-0">+@(_entries.Count - 3) more items</p>
                }
            }
        }
    </div>
}

@code {
    public static readonly WidgetDescriptor Descriptor = new()
    {
        Type = "AppTopItems",
        Name = "App Top Items",
        Description = "Displays the top selling items for a specific app",
        Category = "Apps",
        ComponentType = typeof(AppTopItemsWidget),
        Scope = WidgetScope.Store,
        DefaultColumnSize = 6
    };

    public class AppTopItemsConfig
    {
        public string AppId { get; set; } = "";
    }

    private string? _error;
    private string? _appName;
    private List<AppItemStats>? _entries;

    protected override async Task OnParametersSetAsync()
    {
        if (string.IsNullOrEmpty(StoreId))
            return;

        var config = TypedConfig ?? new AppTopItemsConfig();
        if (string.IsNullOrEmpty(config.AppId))
        {
            Loading = false;
            return;
        }

        Loading = true;
        try
        {
            var app = await AppService.GetApp(config.AppId, null, includeStore: true);
            if (app is null)
            {
                _error = "App not found.";
                return;
            }

            _appName = $"Top Items - {app.Name}";
            var entries = await AppService.GetItemStats(app);
            _entries = entries.Take(5).ToList();
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            Loading = false;
        }
    }
}

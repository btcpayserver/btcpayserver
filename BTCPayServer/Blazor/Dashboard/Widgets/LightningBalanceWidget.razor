@using BTCPayServer.Blazor.Dashboard
@using BTCPayServer.Blazor.Dashboard.Models
@using BTCPayServer.Client
@using BTCPayServer.Configuration
@using BTCPayServer.Data
@using BTCPayServer.Lightning
@using BTCPayServer.Payments
@using BTCPayServer.Payments.Lightning
@using BTCPayServer.Services
@using BTCPayServer.Services.Invoices
@using BTCPayServer.Services.Stores
@using Microsoft.Extensions.Options
@inherits BTCPayServer.Blazor.Dashboard.BaseWidgetComponent<LightningBalanceWidget.LightningBalanceConfig>

@inject StoreRepository StoreRepository
@inject BTCPayNetworkProvider NetworkProvider
@inject LightningClientFactoryService LightningClientFactory
@inject IOptions<LightningNetworkOptions> LightningNetworkOptions
@inject PaymentMethodHandlerDictionary Handlers
@inject LightningHistogramService LnHistogramService
@inject DashboardJsInterop JsInterop

@if (!HasAccess)
{
    <h6>Lightning Balance</h6>
    <p class="text-secondary">@(AccessDeniedMessage ?? "You do not have permission to view this widget.")</p>
}
else if (Loading)
{
    <div class="loading d-flex justify-content-center p-3">
        <div class="spinner-border text-light" role="status">
            <span class="visually-hidden">Loading...</span>
        </div>
    </div>
}
else if (_error is not null)
{
    <header class="d-flex gap-3 align-items-center justify-content-between mb-2">
        <h6>Lightning Balance</h6>
    </header>
    <p class="text-danger">@_error</p>
}
else if (_noLightning)
{
    <h6>Lightning Balance</h6>
    <p class="text-secondary">No Lightning node configured.</p>
}
else if (_balance is not null)
{
    <header class="d-flex gap-3 align-items-center justify-content-between mb-2">
        <h6>Lightning Balance</h6>
    </header>
    <div class="balances d-flex flex-wrap">
        @if (_balance.OffchainBalance != null)
        {
            <div class="balance">
                <div class="d-flex align-items-baseline gap-1">
                    <h3 class="d-inline-block me-1" data-sensitive>@_totalOffchain</h3>
                    <span class="text-secondary fw-semibold text-nowrap">
                        <span class="currency">BTC</span> in channels
                    </span>
                </div>
                <div class="balance-details collapse" id="balanceDetailsOffchain">
                    @if (_balance.OffchainBalance.Opening != null)
                    {
                        <div class="mt-2 d-flex align-items-baseline gap-1">
                            <span class="fw-semibold" data-sensitive>@_balance.OffchainBalance.Opening</span>
                            <span class="text-secondary text-nowrap">
                                <span class="currency">BTC</span> opening channels
                            </span>
                        </div>
                    }
                    @if (_balance.OffchainBalance.Local != null)
                    {
                        <div class="mt-2 d-flex align-items-baseline gap-1">
                            <span class="fw-semibold" data-sensitive>@_balance.OffchainBalance.Local</span>
                            <span class="text-secondary text-nowrap">
                                <span class="currency">BTC</span> local balance
                            </span>
                        </div>
                    }
                    @if (_balance.OffchainBalance.Remote != null)
                    {
                        <div class="mt-2 d-flex align-items-baseline gap-1">
                            <span class="fw-semibold" data-sensitive>@_balance.OffchainBalance.Remote</span>
                            <span class="text-secondary text-nowrap">
                                <span class="currency">BTC</span> remote balance
                            </span>
                        </div>
                    }
                    @if (_balance.OffchainBalance.Closing != null)
                    {
                        <div class="mt-2 d-flex align-items-baseline gap-1">
                            <span class="fw-semibold" data-sensitive>@_balance.OffchainBalance.Closing</span>
                            <span class="text-secondary text-nowrap">
                                <span class="currency">BTC</span> closing channels
                            </span>
                        </div>
                    }
                </div>
            </div>
        }
        @if (_balance.OnchainBalance != null)
        {
            <div class="balance">
                <div class="d-flex align-items-baseline gap-1">
                    <h3 class="d-inline-block me-1" data-sensitive>@_totalOnchain</h3>
                    <span class="text-secondary fw-semibold text-nowrap">
                        <span class="currency">BTC</span> on-chain
                    </span>
                </div>
                <div class="balance-details collapse" id="balanceDetailsOnchain">
                    @if (_balance.OnchainBalance.Confirmed != null)
                    {
                        <div class="mt-2 d-flex align-items-baseline gap-1">
                            <span class="fw-semibold" data-sensitive>@_balance.OnchainBalance.Confirmed</span>
                            <span class="text-secondary text-nowrap">
                                <span class="currency">BTC</span> confirmed
                            </span>
                        </div>
                    }
                    @if (_balance.OnchainBalance.Unconfirmed != null)
                    {
                        <div class="mt-2 d-flex align-items-baseline gap-1">
                            <span class="fw-semibold" data-sensitive>@_balance.OnchainBalance.Unconfirmed</span>
                            <span class="text-secondary text-nowrap">
                                <span class="currency">BTC</span> unconfirmed
                            </span>
                        </div>
                    }
                    @if (_balance.OnchainBalance.Reserved != null)
                    {
                        <div class="mt-2 d-flex align-items-baseline gap-1">
                            <span class="fw-semibold" data-sensitive>@_balance.OnchainBalance.Reserved</span>
                            <span class="text-secondary text-nowrap">
                                <span class="currency">BTC</span> reserved
                            </span>
                        </div>
                    }
                </div>
            </div>
        }
    </div>
    <div class="d-flex flex-wrap align-items-center justify-content-between gap-3 @(_hasHistogram ? "my-3" : "mt-3")">
        @if (_balance.OffchainBalance != null && _balance.OnchainBalance != null)
        {
            <button class="d-inline-flex align-items-center btn btn-link text-primary fw-semibold p-0 ms-n1" type="button"
                    data-bs-toggle="collapse" data-bs-target=".balance-details"
                    aria-expanded="false" aria-controls="balanceDetailsOffchain balanceDetailsOnchain">
                <span class="ms-1">Details</span>
            </button>
        }
    </div>
    @if (_hasHistogram)
    {
        <div id="@_chartId" class="ct-chart ct-major-tenth"></div>
    }
}

@code {
    public static readonly WidgetDescriptor Descriptor = new()
    {
        Type = "LightningBalance",
        Name = "Lightning Balance",
        Description = "Displays Lightning Network node balance and channel info",
        Category = "Lightning",
        ComponentType = typeof(LightningBalanceWidget),
        Scope = WidgetScope.Store,
        DefaultColumnSize = 12,
        CssClass = "store-lightning-balance",
        RequiredStoreFeatures = new[] { "lightning" }
    };

    public class LightningBalanceConfig
    {
        public string CryptoCode { get; set; } = "BTC";
    }

    private string? _error;
    private bool _noLightning;
    private LightningNodeBalance? _balance;
    private NBitcoin.Money? _totalOnchain;
    private LightMoney? _totalOffchain;
    private bool _hasHistogram;
    private List<decimal>? _series;
    private List<DateTimeOffset>? _labels;
    private string _chartId = $"ln-balance-chart-{Guid.NewGuid():N}";

    protected override async Task OnParametersSetAsync()
    {
        if (string.IsNullOrEmpty(StoreId))
            return;

        Loading = true;
        try
        {
            var config = TypedConfig ?? new LightningBalanceConfig();
            var store = await StoreRepository.FindStore(StoreId);
            if (store is null)
            {
                _error = "Store not found.";
                return;
            }

            var lightningClient = GetLightningClient(store, config.CryptoCode);
            if (lightningClient is null)
            {
                _noLightning = true;
                return;
            }

            using var cts = new System.Threading.CancellationTokenSource(TimeSpan.FromSeconds(10));
            _balance = await lightningClient.GetBalance(cts.Token);

            _totalOnchain = _balance.OnchainBalance != null
                ? (_balance.OnchainBalance.Confirmed ?? NBitcoin.Money.Zero) +
                  (_balance.OnchainBalance.Reserved ?? NBitcoin.Money.Zero) +
                  (_balance.OnchainBalance.Unconfirmed ?? NBitcoin.Money.Zero)
                : null;
            _totalOffchain = _balance.OffchainBalance != null
                ? (_balance.OffchainBalance.Opening ?? LightMoney.Zero) +
                  (_balance.OffchainBalance.Local ?? LightMoney.Zero) +
                  (_balance.OffchainBalance.Closing ?? LightMoney.Zero)
                : null;

            var data = await LnHistogramService.GetHistogram(lightningClient, Client.Models.HistogramType.Week, cts.Token);
            if (data != null)
            {
                _series = data.Series;
                _labels = data.Labels;
                _hasHistogram = _series is { Count: > 0 };
            }
        }
        catch (Exception ex) when (ex is NotImplementedException or NotSupportedException)
        {
            _error = "Your node does not support balance fetching.";
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            Loading = false;
        }
    }

    private ILightningClient? GetLightningClient(StoreData store, string cryptoCode)
    {
        var network = NetworkProvider.GetNetwork<BTCPayNetwork>(cryptoCode);
        if (network is null) return null;
        var id = PaymentTypes.LN.GetPaymentMethodId(cryptoCode);
        var existing = store.GetPaymentMethodConfig<LightningPaymentMethodConfig>(id, Handlers);
        if (existing == null) return null;

        if (existing.GetExternalLightningUrl() is { } connectionString)
        {
            return LightningClientFactory.Create(connectionString, network);
        }
        if (existing.IsInternalNode &&
            LightningNetworkOptions.Value.InternalLightningByCryptoCode.TryGetValue(cryptoCode, out var internalNode))
        {
            return internalNode;
        }
        return null;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && _hasHistogram && _series is not null && _labels is not null)
        {
            var labels = _labels.Select(l => l.ToString("MMM dd")).ToArray();
            var series = _series.Select(s => (object)s).ToArray();
            await JsInterop.RenderChart(_chartId, "line", labels, new[] { series });
        }
    }
}

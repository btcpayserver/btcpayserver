@using BTCPayServer
@using BTCPayServer.Blazor.Dashboard
@using BTCPayServer.Blazor.Dashboard.Models
@using BTCPayServer.Client
@using BTCPayServer.Client.Models
@using BTCPayServer.Services
@using BTCPayServer.Services.Invoices
@inherits BTCPayServer.Blazor.Dashboard.BaseWidgetComponent<RecentInvoicesWidget.RecentInvoicesConfig>

@inject InvoiceRepository InvoiceRepository
@inject DisplayFormatter DisplayFormatter

@if (!HasAccess)
{
    <div class="widget-body p-3">
        <h6 class="text-muted">Recent Invoices</h6>
        <p class="text-secondary small">@(AccessDeniedMessage ?? "You do not have permission to view this widget.")</p>
    </div>
}
else if (Loading)
{
    <div class="widget-body p-3">
        <h6 class="text-muted">Recent Invoices</h6>
        <div class="d-flex justify-content-center p-3">
            <div class="spinner-border text-light" role="status">
                <span class="visually-hidden">Loading...</span>
            </div>
        </div>
    </div>
}
else if (_error is not null)
{
    <div class="widget-body p-3">
        <h6 class="text-muted">Recent Invoices</h6>
        <p class="text-danger small">@_error</p>
    </div>
}
else
{
    var config = TypedConfig ?? new RecentInvoicesConfig();
    <div class="widget-body p-3">
        <h6 class="mb-3">Recent Invoices</h6>

        @if (_invoices is null || _invoices.Length == 0)
        {
            <p class="text-muted small mb-0">No invoices in the last @config.LastDays days.</p>
        }
        else if (Size > 6)
        {
            <div class="table-responsive">
                <table class="table table-sm table-hover mb-0">
                    <thead>
                        <tr>
                            <th>Date</th>
                            <th>Invoice</th>
                            <th>Status</th>
                            <th class="text-end">Amount</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var invoice in _invoices)
                        {
                            <tr>
                                <td class="text-muted small">@invoice.InvoiceTime.ToTimeAgo()</td>
                                <td class="small">@invoice.Id</td>
                                <td>
                                    <span class="badge @GetStatusBadgeClass(invoice.Status)">
                                        @invoice.Status
                                    </span>
                                </td>
                                <td class="text-end small">
                                    @DisplayFormatter.Currency(invoice.Price, invoice.Currency)
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="d-flex align-items-baseline gap-2">
                <span class="fs-2 fw-bold">@_invoices.Length</span>
                <span class="text-muted">invoices</span>
            </div>
            <p class="text-muted small mb-0">in last @config.LastDays days</p>
        }
    </div>
}

@code {
    public static readonly WidgetDescriptor Descriptor = new()
    {
        Type = "RecentInvoices",
        Name = "Recent Invoices",
        Description = "Displays a list of recent invoices with status and amount",
        Category = "Store",
        ComponentType = typeof(RecentInvoicesWidget),
        Scope = WidgetScope.Store,
        DefaultColumnSize = 12,
        MinColumnSize = 3
    };

    public class RecentInvoicesConfig
    {
        public int Limit { get; set; } = 5;
        public int LastDays { get; set; } = 30;
    }

    private string? _error;
    private InvoiceEntity[]? _invoices;

    protected override async Task OnParametersSetAsync()
    {
        if (string.IsNullOrEmpty(StoreId))
            return;

        Loading = true;
        try
        {
            var config = TypedConfig ?? new RecentInvoicesConfig();
            var query = new InvoiceQuery
            {
                StoreId = new[] { StoreId },
                StartDate = DateTimeOffset.UtcNow.AddDays(-config.LastDays),
                Take = config.Limit,
                IncludeArchived = false
            };
            _invoices = await InvoiceRepository.GetInvoices(query);
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            Loading = false;
        }
    }

    private static string GetStatusBadgeClass(InvoiceStatus status)
    {
        return status switch
        {
            InvoiceStatus.New => "bg-info",
            InvoiceStatus.Processing => "bg-warning text-dark",
            InvoiceStatus.Settled => "bg-success",
            InvoiceStatus.Expired => "bg-secondary",
            InvoiceStatus.Invalid => "bg-danger",
            _ => "bg-light text-dark"
        };
    }
}

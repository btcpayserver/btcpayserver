@using BTCPayServer.Abstractions.Contracts
@using BTCPayServer.Blazor.Dashboard.Models
@using BTCPayServer.Data
@using BTCPayServer.Payments
@using BTCPayServer.Payments.Bitcoin
@using BTCPayServer.Payments.Lightning
@using BTCPayServer.Services
@using BTCPayServer.Services.Invoices
@using BTCPayServer.Services.Stores
@inherits BTCPayServer.Blazor.Dashboard.BaseWidgetComponent<SetupGuideWidget.SetupGuideConfig>

@inject BTCPayNetworkProvider NetworkProvider
@inject PaymentMethodHandlerDictionary Handlers
@inject StoreRepository StoreRepository
@inject IEnumerable<IStoreSetupStepProvider> SetupStepProviders

@if (!HasAccess)
{
    return;
}

@if (_allDone)
{
    <header>
        <h5 class="mb-3 text-muted">Your store is fully set up!</h5>
    </header>
}
else if (_anyPaymentMethodEnabled)
{
    <header>
        <h5 class="mb-3 text-muted">This store is ready to accept transactions, good job!</h5>
    </header>
}
else
{
    <p class="lead text-secondary mb-3">To start accepting payments, set up a wallet or a Lightning node.</p>
}
<div class="list-group" id="SetupGuide">
    @* "Create your store" — always completed *@
    <div class="list-group-item d-flex align-items-center">
        <svg role="img" class="icon icon-done me-3" style="width:1.5rem;height:1.5rem;"><use href="/img/icon-sprite.svg#done"></use></svg>
        <div class="content">
            <h5 class="mb-0 text-success">Create your store</h5>
        </div>
    </div>
    @* Built-in and plugin setup steps, sorted by order *@
    @foreach (var step in _steps.OrderBy(s => s.Order))
    {
        @if (step.IsComplete)
        {
            <div class="list-group-item d-flex align-items-center">
                <svg role="img" class="icon icon-done me-3" style="width:1.5rem;height:1.5rem;"><use href="/img/icon-sprite.svg#done"></use></svg>
                <div class="content">
                    <h5 class="mb-0 text-success">@step.Title</h5>
                </div>
            </div>
        }
        else if (!string.IsNullOrEmpty(step.SetupUrl))
        {
            <a href="@step.SetupUrl"
               class="list-group-item list-group-item-action d-flex align-items-center order-1">
                <svg role="img" class="icon icon-@step.IconSymbol me-3" style="width:1.5rem;height:1.5rem;"><use href="/img/icon-sprite.svg#@step.IconSymbol"></use></svg>
                <div class="content flex-fill">
                    <h5 class="mb-0">@step.Title</h5>
                </div>
                <svg role="img" class="icon icon-caret-right" style="width:1.5rem;height:1.5rem;"><use href="/img/icon-sprite.svg#caret-right"></use></svg>
            </a>
        }
    }
</div>

@code {
    public class SetupGuideConfig { }

    private bool _walletEnabled;
    private bool _lightningEnabled;
    private bool _lightningSupported;
    private bool _anyPaymentMethodEnabled;
    private string _cryptoCode = "BTC";
    private bool _allDone;
    private List<StoreSetupStep> _steps = new();

    protected override async Task OnParametersSetAsync()
    {
        if (!DataParametersChanged)
            return;

        if (string.IsNullOrEmpty(StoreId))
            return;

        Loading = true;
        try
        {
            _cryptoCode = NetworkProvider.DefaultCryptoCode;
            _lightningSupported = NetworkProvider.GetNetwork<BTCPayNetwork>(_cryptoCode)?.SupportLightning is true;

            var store = await StoreRepository.FindStore(StoreId);
            if (store is null)
                return;

            var storeBlob = store.GetStoreBlob();
            var excludeFilters = storeBlob.GetExcludedPaymentMethods();

            // Check wallet
            var derivations = store.GetPaymentMethodConfigs<DerivationSchemeSettings>(Handlers);
            _walletEnabled = derivations.Any(kv =>
            {
                var pretty = kv.Value?.ToPrettyString();
                return !string.IsNullOrEmpty(pretty) && !excludeFilters.Match(kv.Key);
            });

            // Check lightning
            var lightningConfigs = store.GetPaymentMethodConfigs(Handlers)
                .Where(c => c.Value is LightningPaymentMethodConfig);
            _lightningEnabled = lightningConfigs.Any(kv =>
            {
                var config = (LightningPaymentMethodConfig)kv.Value;
                return !string.IsNullOrEmpty(config.GetDisplayableConnectionString())
                       && !excludeFilters.Match(kv.Key);
            });

            _anyPaymentMethodEnabled = _walletEnabled || _lightningEnabled;

            // Build the steps list
            _steps.Clear();

            // Wallet step
            _steps.Add(new StoreSetupStep
            {
                Title = "Set up a wallet",
                SetupUrl = $"/stores/{StoreId}/onchain/{_cryptoCode}",
                IsComplete = _walletEnabled,
                Order = 10,
                IconSymbol = "wallet-new"
            });

            // Lightning step (only if supported)
            if (_lightningSupported)
            {
                _steps.Add(new StoreSetupStep
                {
                    Title = "Set up a Lightning node",
                    SetupUrl = $"/stores/{StoreId}/lightning/{_cryptoCode}/setup",
                    IsComplete = _lightningEnabled,
                    Order = 20,
                    IconSymbol = "wallet-new"
                });
            }

            // Plugin-contributed steps
            var context = new StoreSetupStepContext { StoreId = StoreId, CryptoCode = _cryptoCode };
            foreach (var provider in SetupStepProviders)
            {
                try
                {
                    var pluginSteps = await provider.GetStepsAsync(context);
                    _steps.AddRange(pluginSteps);
                }
                catch
                {
                    // Don't let a faulty plugin break the setup guide
                }
            }

            _allDone = _steps.All(s => s.IsComplete);
        }
        catch
        {
            // On error, steps list stays empty — widget will just show "fully set up"
            _allDone = true;
        }
        finally
        {
            Loading = false;
        }
    }

    public static readonly WidgetDescriptor Descriptor = new()
    {
        Type = "SetupGuide",
        Name = "Setup Guide",
        Description = "Shows setup steps for wallet and Lightning configuration",
        Category = "Utility",
        Scope = WidgetScope.Store,
        DefaultColumnSize = 4,
        MinColumnSize = 3,
        MaxColumnSize = 12,
        MinRowSpan = 1,
        MaxRowSpan = 2,
        CssClass = "setup-guide"
    };
}

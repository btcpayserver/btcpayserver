@using BTCPayServer.Blazor.Dashboard
@using BTCPayServer.Blazor.Dashboard.Models
@using BTCPayServer.Client
@using BTCPayServer.Client.Models
@using BTCPayServer.Data
@using BTCPayServer.Services.Invoices
@using Microsoft.EntityFrameworkCore
@inherits BTCPayServer.Blazor.Dashboard.BaseWidgetComponent<StoreNumbersWidget.StoreNumbersConfig>

@inject InvoiceRepository InvoiceRepository
@inject ApplicationDbContextFactory DbContextFactory

@if (!HasAccess)
{
    <div class="widget-body p-3">
        <h6 class="text-muted">Store Numbers</h6>
        <p class="text-secondary small">@(AccessDeniedMessage ?? "You do not have permission to view this widget.")</p>
    </div>
}
else if (Loading)
{
    <div class="widget-body p-3">
        <h6 class="text-muted">Store Numbers</h6>
        <div class="d-flex justify-content-center p-3">
            <div class="spinner-border text-light" role="status">
                <span class="visually-hidden">Loading...</span>
            </div>
        </div>
    </div>
}
else if (_error is not null)
{
    <div class="widget-body p-3">
        <h6 class="text-muted">Store Numbers</h6>
        <p class="text-danger small">@_error</p>
    </div>
}
else
{
    var config = TypedConfig ?? new StoreNumbersConfig();
    <div class="widget-body p-3">
        <h6 class="mb-3">Store Numbers</h6>
        @if (Size > 6)
        {
            <div class="row g-3">
                <div class="col-4 text-center">
                    <div class="fs-3 fw-bold">@_paidInvoices</div>
                    <div class="text-muted small">Paid Invoices</div>
                </div>
                <div class="col-4 text-center">
                    <div class="fs-3 fw-bold">@_payoutsPending</div>
                    <div class="text-muted small">Pending Payouts</div>
                </div>
                <div class="col-4 text-center">
                    <div class="fs-3 fw-bold">@_refundsIssued</div>
                    <div class="text-muted small">Refunds</div>
                </div>
            </div>
            <p class="text-muted small mt-2 mb-0">in last @config.TimeframeDays days</p>
        }
        else
        {
            <div class="d-flex align-items-baseline gap-2">
                <span class="fs-2 fw-bold">@_paidInvoices</span>
                <span class="text-muted">Paid Invoices</span>
            </div>
            @if (_payoutsPending > 0)
            {
                <div class="text-muted small">@_payoutsPending pending payouts</div>
            }
            @if (_refundsIssued > 0)
            {
                <div class="text-muted small">@_refundsIssued refunds</div>
            }
            <p class="text-muted small mb-0">in last @config.TimeframeDays days</p>
        }
    </div>
}

@code {
    public static readonly WidgetDescriptor Descriptor = new()
    {
        Type = "StoreNumbers",
        Name = "Store Numbers",
        Description = "Shows key store metrics: paid invoices, pending payouts, and refunds",
        Category = "Store",
        ComponentType = typeof(StoreNumbersWidget),
        Scope = WidgetScope.Store,
        DefaultColumnSize = 6
    };

    public class StoreNumbersConfig
    {
        public int TimeframeDays { get; set; } = 7;
    }

    private string? _error;
    private int _paidInvoices;
    private int _payoutsPending;
    private int _refundsIssued;

    protected override async Task OnParametersSetAsync()
    {
        if (string.IsNullOrEmpty(StoreId))
            return;

        Loading = true;
        try
        {
            var config = TypedConfig ?? new StoreNumbersConfig();
            var offset = DateTimeOffset.UtcNow.AddDays(-config.TimeframeDays);

            _paidInvoices = await InvoiceRepository.GetInvoiceCount(
                new InvoiceQuery
                {
                    StoreId = new[] { StoreId },
                    StartDate = offset,
                    Status = new[] { "paid", "confirmed" }
                });

            await using var ctx = DbContextFactory.CreateContext();
            _payoutsPending = await ctx.Payouts
                .Where(p => p.PullPaymentData.StoreId == StoreId
                         && !p.PullPaymentData.Archived
                         && p.State == PayoutState.AwaitingApproval)
                .CountAsync();

            _refundsIssued = await ctx.Invoices
                .Where(i => i.StoreData.Id == StoreId && !i.Archived && i.Created >= offset)
                .SelectMany(i => i.Refunds)
                .CountAsync();
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            Loading = false;
        }
    }
}

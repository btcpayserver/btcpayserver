@using BTCPayServer.Blazor.Dashboard.Models
@using Newtonsoft.Json.Linq
@inherits BTCPayServer.Blazor.Dashboard.BaseWidgetComponent<TodoWidget.TodoConfig>

<header class="mb-2">
    <h6 class="mb-0">@(TypedConfig?.Title ?? "Todo")</h6>
</header>
@if (TypedConfig?.Items is null || TypedConfig.Items.Count == 0)
{
    <p class="text-muted small mb-0">No items yet.</p>
}
else
{
    <div class="list-group list-group-flush">
        @foreach (var item in TypedConfig.Items)
        {
            var localItem = item;
            <label class="list-group-item list-group-item-action d-flex align-items-center gap-2 py-1 px-0 border-0 small">
                <input type="checkbox" class="form-check-input m-0"
                       checked="@localItem.Completed"
                       disabled="@Readonly"
                       @onchange="() => ToggleItem(localItem)" />
                <span class="@(localItem.Completed ? "text-decoration-line-through text-muted" : "")">
                    @localItem.Text
                </span>
            </label>
        }
    </div>
}
@if (!Readonly)
{
    <div class="mt-2 d-flex gap-1">
        <input type="text" class="form-control form-control-sm" placeholder="Add item..."
               @bind="_newItemText" @bind:event="oninput"
               @onkeydown="OnAddKeyDown" />
        <button class="btn btn-outline-primary btn-sm" @onclick="AddItem" disabled="@string.IsNullOrWhiteSpace(_newItemText)">+</button>
    </div>
}

@code {
    private string _newItemText = "";

    public class TodoItem
    {
        public string Text { get; set; } = "";
        public bool Completed { get; set; }
    }

    public class TodoConfig
    {
        public string Title { get; set; } = "Todo";
        public System.Collections.Generic.List<TodoItem> Items { get; set; } = new();
    }

    private async System.Threading.Tasks.Task ToggleItem(TodoItem item)
    {
        item.Completed = !item.Completed;
        await ConfigChanged.InvokeAsync(Config);
    }

    private async System.Threading.Tasks.Task AddItem()
    {
        if (string.IsNullOrWhiteSpace(_newItemText)) return;
        var config = TypedConfig ?? new TodoConfig();
        config.Items.Add(new TodoItem { Text = _newItemText.Trim() });
        _newItemText = "";
        TypedConfig = config;
        await ConfigChanged.InvokeAsync(JObject.FromObject(config));
    }

    private async System.Threading.Tasks.Task OnAddKeyDown(Microsoft.AspNetCore.Components.Web.KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
            await AddItem();
    }

    public static readonly WidgetDescriptor Descriptor = new()
    {
        Type = "Todo",
        Name = "Todo List",
        Description = "A checklist to track tasks",
        Category = "Utility",
        Scope = WidgetScope.Universal,
        AlwaysInteractive = true,
        MinColumnSize = 2,
        MaxColumnSize = 12,
        DefaultColumnSize = 4,
        ConfigSchema = new()
        {
            ["Title"] = new ConfigFieldSchema { Label = "Title", FieldType = ConfigFieldType.Text },
            ["Items"] = new ConfigFieldSchema { FieldType = ConfigFieldType.Hidden }
        }
    };
}

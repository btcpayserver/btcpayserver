@using BTCPayServer.Plugins.Dashboard.Models
@using BTCPayServer.Data
@using BTCPayServer.Payments
@using BTCPayServer.Payments.Bitcoin
@using BTCPayServer.Payments.Lightning
@using BTCPayServer.Services.Apps
@using BTCPayServer.Services.Invoices
@using BTCPayServer.Services.Stores
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.Routing
@using Microsoft.Extensions.Localization
@using Microsoft.Extensions.Logging
@using Microsoft.Extensions.Options
@using Newtonsoft.Json
@using Newtonsoft.Json.Linq
@inject DashboardService DashboardService
@inject WidgetRegistry WidgetRegistry
@inject DashboardJsInterop JsInterop
@inject AuthenticationStateProvider AuthStateProvider
@inject NavigationManager NavigationManager
@inject StoreRepository StoreRepository
@inject BTCPayNetworkProvider NetworkProvider
@inject PaymentMethodHandlerDictionary Handlers
@inject AppService AppService
@inject IEnumerable<BTCPayServer.Abstractions.Contracts.IStoreSetupStepProvider> SetupStepProviders
@inject IOptions<BTCPayServer.Configuration.LightningNetworkOptions> LightningNetworkOptions
@inject LinkGenerator LinkGenerator
@inject IStringLocalizer StringLocalizer
@inject ILogger<DashboardPage> Logger
@implements IAsyncDisposable

@if (!IsSetUp)
{
    <p class="lead text-secondary mt-2">To start accepting payments, set up a wallet or a Lightning node.</p>
    <div class="list-group" id="SetupGuide" style="max-width: 30em;">
        <div class="list-group-item d-flex align-items-center">
            <svg role="img" class="icon icon-done me-3" style="width:1.5rem;height:1.5rem;"><use href="/img/icon-sprite.svg#done"></use></svg>
            <div class="content">
                <h5 class="mb-0 text-success">Create your store</h5>
            </div>
        </div>
        @foreach (var step in _setupSteps.OrderBy(s => s.Order))
        {
            @if (step.IsComplete)
            {
                <div class="list-group-item d-flex align-items-center">
                    <svg role="img" class="icon icon-done me-3" style="width:1.5rem;height:1.5rem;"><use href="/img/icon-sprite.svg#done"></use></svg>
                    <div class="content">
                        <h5 class="mb-0 text-success">@step.Title</h5>
                    </div>
                </div>
            }
            else if (!string.IsNullOrEmpty(step.SetupUrl))
            {
                <a href="@step.SetupUrl"
                   class="list-group-item list-group-item-action d-flex align-items-center order-1">
                    <svg role="img" class="icon icon-@step.IconSymbol me-3" style="width:1.5rem;height:1.5rem;"><use href="/img/icon-sprite.svg#@step.IconSymbol"></use></svg>
                    <div class="content flex-fill">
                        <h5 class="mb-0">@step.Title</h5>
                    </div>
                    <svg role="img" class="icon icon-caret-right" style="width:1.5rem;height:1.5rem;"><use href="/img/icon-sprite.svg#caret-right"></use></svg>
                </a>
            }
        }
    </div>
}
else
{

<div class="dashboard-header d-flex justify-content-between align-items-center mb-4">
    <div class="d-flex align-items-center gap-3">
        @if (EditMode && _activeDashboard is not null)
        {
            <input type="text" class="form-control form-control-sm fw-bold fs-5"
                   style="width: auto; min-width: 150px; max-width: 300px;"
                   value="@_activeDashboard.Name"
                   @onchange="OnDashboardNameChanged" />
        }
        else
        {
            <h3 class="mb-0">@(_activeDashboard?.Name ?? "Dashboard")</h3>
        }
        @if (_activeDashboard is not null)
        {
            <span class="badge bg-light text-dark">@_activeScope</span>
            @if (_isCodeDefault)
            {
                <span class="badge bg-secondary text-white" title="This is the auto-generated default layout. It updates automatically when plugins add new widgets. Editing will create a saved copy.">Auto</span>
            }
            else if (_activeDashboard.IsDefault)
            {
                <span class="badge bg-info text-white">Default</span>
            }
        }
        <div class="dropdown">
            <button class="btn btn-link btn-sm dropdown-toggle p-0" type="button"
                    data-bs-toggle="dropdown" aria-expanded="false">
                Switch
            </button>
            <div class="dropdown-menu" style="min-width: 260px;">
                @if (_allDashboards.Count > 0)
                {
                    @foreach (var group in _allDashboards.GroupBy(d => d.Scope))
                    {
                        <div class="dropdown-header small text-uppercase">@group.Key</div>
                        @foreach (var db in group)
                        {
                            <button class="dropdown-item @(db.Id == _activeDashboard?.Id ? "active" : "")"
                                    @onclick="() => SwitchDashboard(db)">
                                @db.Name
                                @if (db.IsDefault)
                                {
                                    <span class="badge bg-light text-dark ms-1">Default</span>
                                }
                            </button>
                        }
                    }
                    <div class="dropdown-divider"></div>
                }
                <div class="dropdown-header small text-uppercase">New Empty Dashboard</div>
                <button class="dropdown-item" @onclick="() => CreateNewDashboard(DashboardScope.Store, false)">
                    + Store Dashboard
                </button>
                @if (_isAdmin)
                {
                    <button class="dropdown-item" @onclick="() => CreateNewDashboard(DashboardScope.Server, false)">
                        + Server Dashboard
                    </button>
                }
                @if (_activeDashboard is not null && _activeDashboard.Widgets.Count > 0)
                {
                    <div class="dropdown-divider"></div>
                    <div class="dropdown-header small text-uppercase">Copy Current Layout To</div>
                    <button class="dropdown-item" @onclick="() => CreateNewDashboard(DashboardScope.Store, true)">
                        + Store Dashboard
                    </button>
                    @if (_isAdmin)
                    {
                        <button class="dropdown-item" @onclick="() => CreateNewDashboard(DashboardScope.Server, true)">
                            + Server Dashboard
                        </button>
                    }
                }
            </div>
        </div>
    </div>

    <div class="d-flex gap-2 align-items-center">
        @if (EditMode)
        {
            <DashboardWidgetPicker Registry="WidgetRegistry"
                                   DashboardScope="@(_activeScope)"
                                   IsAdmin="_isAdmin"
                                   OnWidgetAdded="AddWidget" />
            @if (_confirmDelete)
            {
                <span class="text-danger small me-1">Delete this dashboard?</span>
                <button class="btn btn-danger btn-sm" @onclick="DeleteDashboard">Yes, Delete</button>
                <button class="btn btn-outline-secondary btn-sm" @onclick="() => _confirmDelete = false">Cancel</button>
            }
            else
            {
                <div class="dropdown">
                    <button class="btn btn-outline-secondary btn-sm dropdown-toggle" type="button"
                            data-bs-toggle="dropdown" disabled="@_widgetEditMode">
                        Actions
                    </button>
                    <div class="dropdown-menu dropdown-menu-end">
                        @if (_activeDashboard is not null && !_activeDashboard.IsDefault)
                        {
                            <button class="dropdown-item" @onclick="SetAsDefault">Set as Default</button>
                        }
                        <button class="dropdown-item" @onclick="CopyDashboardLink">
                            @(_linkCopied ? "Copied!" : "Copy Link")
                        </button>
                        <div class="dropdown-divider"></div>
                        <button class="dropdown-item" @onclick="ExportDashboard">Export</button>
                        <label class="dropdown-item mb-0" style="cursor: pointer;">
                            Import
                            <input type="file" accept=".json" @ref="_importFileInput" @onchange="ImportDashboard" hidden />
                        </label>
                        @if (_activeDashboard is not null && _activeDashboard.Widgets.Count > 0)
                        {
                            <div class="dropdown-divider"></div>
                            <button class="dropdown-item" @onclick="ResetToDefaultLayout">Reset to Default</button>
                        }
                        <div class="dropdown-divider"></div>
                        <button class="dropdown-item text-danger" @onclick="() => _confirmDelete = true">Delete Dashboard</button>
                    </div>
                </div>
            }
            <button class="btn btn-primary btn-sm" disabled="@_widgetEditMode" @onclick="ExitEditMode">Done</button>
        }
        else
        {
            @if (CanEditActiveDashboard())
            {
                <button class="btn btn-link btn-sm" @onclick="EnterEditMode">Edit</button>
            }
        }
    </div>
</div>

<div @ref="_gridContainer" class="grid-stack @(EditMode ? "dashboard-edit" : "")">
    @if (_activeDashboard is not null && _activeDashboard.Widgets.Count > 0)
    {
        @foreach (var wp in ComputeGridPositions())
        {
            var descriptor = WidgetRegistry.GetDescriptor(wp.Placement.WidgetType);
            var isConfiguring = _configuringPlacement?.Id == wp.Placement.Id;
            <div @key="wp.Placement.Id"
                 class="grid-stack-item @(isConfiguring ? "widget-configuring" : "")"
                 gs-id="@wp.Placement.Id"
                 gs-x="@wp.X"
                 gs-y="@wp.Y"
                 gs-w="@wp.W"
                 gs-h="@wp.Placement.RowSpan">
                <div class="grid-stack-item-content">
                    @if (descriptor is null)
                    {
                        <WidgetUnavailable Placement="wp.Placement"
                                           EditMode="EditMode"
                                           OnRemove="() => RemoveWidget(wp.Placement)" />
                    }
                    else
                    {
                        <WidgetContainer Placement="wp.Placement"
                                         Descriptor="descriptor"
                                         StoreId="@StoreId"
                                         UserId="@UserId"
                                         DashboardScope="_activeScope"
                                         EditMode="EditMode"
                                         WidgetEditMode="_widgetEditMode"
                                         ActiveStoreFeatures="_activeStoreFeatures"
                                         OnConfigChanged="(config) => OnWidgetConfigChanged(wp.Placement, config)"
                                         OnEditModeChanged="(editing) => OnWidgetEditMode(editing)"
                                         OnRemove="() => RemoveWidget(wp.Placement)"
                                         OnSizeChanged="(size) => OnWidgetSizeChanged(size)"
                                         OnConfigure="() => OpenConfigPanel(wp.Placement, descriptor)" />
                    }
                </div>
            </div>
        }
    }
    else if (_activeDashboard is not null)
    {
        <div class="dashboard-empty text-center py-5">
            <h5 class="text-muted mb-3">This dashboard is empty</h5>
            <p class="text-secondary mb-3">Add widgets manually or start with the default layout.</p>
            <button class="btn btn-primary" @onclick="PopulateDefaultLayout">Populate Default Layout</button>
        </div>
    }
</div>

<WidgetConfigPanel Visible="_configuringPlacement is not null"
                   Descriptor="_configuringDescriptor"
                   Placement="_configuringPlacement"
                   OnSave="SaveWidgetConfig"
                   OnClose="CloseConfigPanel" />

} @* end of IsSetUp else block *@

@code {
    [Parameter] public string StoreId { get; set; } = string.Empty;
    [Parameter] public string UserId { get; set; } = string.Empty;
    [Parameter] public string? DashboardId { get; set; }
    [Parameter] public bool IsSetUp { get; set; }
    [Parameter] public bool WalletEnabled { get; set; }
    [Parameter] public bool LightningEnabled { get; set; }
    [Parameter] public bool LightningSupported { get; set; }
    [Parameter] public string CryptoCode { get; set; } = "BTC";

    private DashboardDefinition? _activeDashboard;
    private DashboardScope _activeScope;
    private List<DashboardDefinition> _allDashboards = new();
    private bool _widgetEditMode;
    private bool _confirmDelete;
    private bool _linkCopied;
    private bool _isAdmin;
    private bool _isCodeDefault; // true when active dashboard is a freshly generated code default (not persisted)
    private HashSet<string> _activeStoreFeatures = new(); // e.g. "wallet", "lightning"
    private List<BTCPayServer.Data.AppData> _apps = new(); // store apps for template context
    private DotNetObjectReference<object>? _dotNetRef;
    private readonly System.Threading.CancellationTokenSource _disposeCts = new();
    private ElementReference _gridContainer;
    private ElementReference _importFileInput;
    private bool _gridInitialized;

    // Widget config panel state
    private WidgetPlacement? _configuringPlacement;
    private WidgetDescriptor? _configuringDescriptor;
    private bool _pendingConfiguration; // true when a newly added widget requires config before saving
    private bool _editDirty; // true when the user has made changes during the current edit session
    private List<BTCPayServer.Abstractions.Contracts.StoreSetupStep> _setupSteps = new(); // setup guide steps

    public bool EditMode { get; set; }

    protected override async Task OnParametersSetAsync()
    {
        // Determine admin status
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        _isAdmin = authState.User.IsInRole(Roles.ServerAdmin);

        // Fetch store configuration directly instead of relying on parameters,
        // which may lose their values across Blazor circuit reconnection.
        await RefreshStoreConfig();

        var context = BuildTemplateContext();

        // Load dashboards from all scopes and build the unified list
        await LoadAllDashboards();

        _isCodeDefault = false;

        // Re-bind the active dashboard against the freshly loaded collections.
        // On same-component navigation (e.g. switching stores), _activeDashboard
        // would otherwise survive and be re-injected into _allDashboards below,
        // surfacing the previous store's dashboard in the new context — and
        // potentially saving it back into the wrong scope.
        var requestedDashboardId = DashboardId ?? _activeDashboard?.Id;
        _activeDashboard = !string.IsNullOrEmpty(requestedDashboardId)
            ? _allDashboards.FirstOrDefault(d => d.Id == requestedDashboardId)
            : null;

        // Otherwise resolve active: user > store > server > code default
        if (_activeDashboard is null)
        {
            // Normalize empty StoreId to null — the service treats null as "no scope" but
            // would happily key dashboards on an empty string and pick the wrong fallback.
            var resolvedStoreId = string.IsNullOrEmpty(StoreId) ? null : StoreId;
            _activeDashboard = await DashboardService.ResolveActiveDashboard(resolvedStoreId, context, _isAdmin);
            // ResolveActiveDashboard may have removed a stale auto-materialized dashboard
            // from storage. Reload _allDashboards so the switcher doesn't show a deleted
            // entry that, if selected, could resurrect the stale dashboard on the next save.
            await LoadAllDashboards();
            // If the resolved dashboard isn't in any saved collection, it's a code-generated default.
            // This means it was freshly generated from templates + plugin contributors and will
            // always reflect the latest plugin additions on each page load.
            _isCodeDefault = _activeDashboard is not null
                             && _allDashboards.All(d => d.Id != _activeDashboard.Id);
        }

        // Determine which scope the active dashboard came from
        _activeScope = DetermineActiveScope(_activeDashboard);

        // Ensure the active dashboard is in the list (for the switcher UI)
        if (_activeDashboard is not null && _allDashboards.All(d => d.Id != _activeDashboard.Id))
        {
            _allDashboards.Add(_activeDashboard);
        }

        await base.OnParametersSetAsync();
    }

    /// <summary>
    /// Fetches the store's actual payment method configuration to determine
    /// WalletEnabled, LightningEnabled, IsSetUp, CryptoCode, and Apps.
    /// This ensures the dashboard always reflects the current store state,
    /// regardless of parameter serialization across Blazor circuit reconnection.
    /// </summary>
    private async Task RefreshStoreConfig()
    {
        if (string.IsNullOrEmpty(StoreId)) return;

        var store = await StoreRepository.FindStore(StoreId);
        if (store is null) return;

        var storeBlob = store.GetStoreBlob();
        // Preserve the incoming/store-specific CryptoCode; only fall back to the server
        // default when nothing was passed. Hardcoding the server default would point the
        // setup guide and template context at the wrong payment method on non-default stores.
        if (string.IsNullOrEmpty(CryptoCode))
            CryptoCode = NetworkProvider.DefaultCryptoCode;

        // Detect wallet (on-chain) configuration
        var derivationByCryptoCode = store
            .GetPaymentMethodConfigs<DerivationSchemeSettings>(Handlers)
            .ToDictionary(
                c => ((IHasNetwork)Handlers[c.Key]).Network.CryptoCode,
                c => c.Value);
        var excludeFilters = storeBlob.GetExcludedPaymentMethods();

        WalletEnabled = false;
        foreach (var handler in Handlers)
        {
            if (handler is BitcoinLikePaymentHandler { Network: var network })
            {
                derivationByCryptoCode.TryGetValue(network.CryptoCode, out var strategy);
                if (strategy != null && !excludeFilters.Match(handler.PaymentMethodId))
                {
                    WalletEnabled = true;
                    break;
                }
            }
        }

        // Detect Lightning configuration
        var lightningByCryptoCode = store
            .GetPaymentMethodConfigs(Handlers)
            .Where(c => c.Value is LightningPaymentMethodConfig)
            .ToDictionary(
                c => ((IHasNetwork)Handlers[c.Key]).Network.CryptoCode,
                c => (LightningPaymentMethodConfig)c.Value);

        LightningEnabled = false;
        foreach (var handler in Handlers)
        {
            if (handler is LightningLikePaymentHandler)
            {
                var lnNetwork = ((IHasNetwork)handler).Network;
                lightningByCryptoCode.TryGetValue(lnNetwork.CryptoCode, out var lightning);
                if (lightning != null && !excludeFilters.Match(handler.PaymentMethodId))
                {
                    LightningEnabled = true;
                    break;
                }
            }
        }

        LightningSupported = NetworkProvider.GetNetwork<BTCPayNetwork>(CryptoCode)?.SupportLightning is true;

        // Any payment method at all
        IsSetUp = WalletEnabled || LightningEnabled
                  || store.GetPaymentMethodConfigs(onlyEnabled: true).Count > 0;

        // Build active store features set for widget availability checks
        _activeStoreFeatures.Clear();
        if (WalletEnabled) _activeStoreFeatures.Add("wallet");
        if (LightningEnabled) _activeStoreFeatures.Add("lightning");

        // Load apps for the template context
        _apps.Clear();
        if (!string.IsNullOrEmpty(UserId))
        {
            var apps = await AppService.GetAllApps(UserId, false, StoreId);
            foreach (var app in apps)
            {
                if (app.App is not null)
                    _apps.Add(app.App);
            }
        }

        // Build setup steps for the inline setup guide (shown when !IsSetUp)
        _setupSteps.Clear();
        _setupSteps.Add(new BTCPayServer.Abstractions.Contracts.StoreSetupStep
        {
            Title = StringLocalizer["Set up a wallet"],
            SetupUrl = LinkGenerator.GetPathByAction(
                action: "SetupWallet",
                controller: "UIStores",
                values: new { storeId = StoreId, cryptoCode = CryptoCode }),
            IsComplete = WalletEnabled,
            Order = 10,
            IconSymbol = "wallet-new"
        });
        if (LightningSupported)
        {
            _setupSteps.Add(new BTCPayServer.Abstractions.Contracts.StoreSetupStep
            {
                Title = StringLocalizer["Set up a Lightning node"],
                SetupUrl = LinkGenerator.GetPathByAction(
                    action: "SetupLightningNode",
                    controller: "UIStores",
                    values: new { storeId = StoreId, cryptoCode = CryptoCode }),
                IsComplete = LightningEnabled,
                Order = 20,
                IconSymbol = "wallet-new"
            });
        }
        // Plugin-contributed setup steps
        var setupContext = new BTCPayServer.Abstractions.Contracts.StoreSetupStepContext
        {
            StoreId = StoreId,
            CryptoCode = CryptoCode
        };
        foreach (var provider in SetupStepProviders)
        {
            try
            {
                var pluginSteps = await provider.GetStepsAsync(setupContext);
                _setupSteps.AddRange(pluginSteps);
            }
            catch (Exception ex)
            {
                // Don't let a faulty plugin break the setup guide for everyone else.
                Logger.LogError(ex, "Setup step provider {Provider} threw while contributing dashboard setup steps", provider.GetType().FullName);
            }
        }
    }

    private DashboardTemplateContext BuildTemplateContext()
    {
        return new DashboardTemplateContext
        {
            CryptoCode = CryptoCode,
            WalletEnabled = WalletEnabled,
            LightningEnabled = LightningEnabled,
            HasInternalLightningNode = LightningNetworkOptions.Value.InternalLightningByCryptoCode.ContainsKey(CryptoCode),
            Apps = _apps
        };
    }

    private async Task LoadAllDashboards()
    {
        _allDashboards = new List<DashboardDefinition>();

        // Server dashboards — admin-only. Server-scope content (e.g. operational notes)
        // is intended for server administrators and must not surface to non-admin users
        // through the switcher or fallback resolution path.
        if (_isAdmin)
        {
            var serverCollection = await DashboardService.GetServerDashboards();
            foreach (var d in serverCollection.Dashboards)
            {
                d.Scope = DashboardScope.Server;
                _allDashboards.Add(d);
            }
        }

        // Store dashboards
        if (!string.IsNullOrEmpty(StoreId))
        {
            var storeCollection = await DashboardService.GetStoreDashboards(StoreId);
            foreach (var d in storeCollection.Dashboards)
            {
                d.Scope = DashboardScope.Store;
                _allDashboards.Add(d);
            }
        }
    }

    private DashboardScope DetermineActiveScope(DashboardDefinition? dashboard)
    {
        if (dashboard is null) return DashboardScope.Store;
        return dashboard.Scope;
    }

    private bool CanEditActiveDashboard()
    {
        if (_activeDashboard is null) return false;
        return _activeScope switch
        {
            DashboardScope.Server => _isAdmin,
            DashboardScope.Store => true,  // store access already implied by being on the page
            _ => false
        };
    }

    private async Task SetAsDefault()
    {
        if (_activeDashboard is null) return;

        // Clear IsDefault on all dashboards in the same scope, then set on current
        foreach (var d in _allDashboards.Where(d => d.Scope == _activeScope))
            d.IsDefault = false;
        _activeDashboard.IsDefault = true;

        // Persist the change to the scope's collection
        switch (_activeScope)
        {
            case DashboardScope.Store when !string.IsNullOrEmpty(StoreId):
            {
                var collection = await DashboardService.GetStoreDashboards(StoreId);
                foreach (var d in collection.Dashboards) d.IsDefault = false;
                var target = collection.Dashboards.FirstOrDefault(d => d.Id == _activeDashboard.Id);
                if (target is not null) target.IsDefault = true;
                collection.ActiveDashboardId = _activeDashboard.Id;
                await DashboardService.SaveStoreDashboards(StoreId, collection);
                break;
            }
            case DashboardScope.Server:
            {
                var collection = await DashboardService.GetServerDashboards();
                foreach (var d in collection.Dashboards) d.IsDefault = false;
                var target = collection.Dashboards.FirstOrDefault(d => d.Id == _activeDashboard.Id);
                if (target is not null) target.IsDefault = true;
                collection.ActiveDashboardId = _activeDashboard.Id;
                await DashboardService.SaveServerDashboards(collection);
                break;
            }
        }
    }

    private async Task PopulateDefaultLayout()
    {
        await ApplyDefaultTemplate();
    }

    private async Task ResetToDefaultLayout()
    {
        await ApplyDefaultTemplate();
    }

    private async Task ApplyDefaultTemplate()
    {
        if (_activeDashboard is null) return;

        var template = DashboardService.GetDefaultTemplate(_activeScope, BuildTemplateContext());
        _activeDashboard.Widgets = template.Widgets;
        await SaveDashboard();
        await ResetGrid();
    }

    private async Task CopyDashboardLink()
    {
        if (_activeDashboard is null) return;
        var uri = new Uri(NavigationManager.Uri);
        var link = $"{uri.GetLeftPart(UriPartial.Path)}?dashboardId={_activeDashboard.Id}";
        await JsInterop.CopyToClipboard(link);
        _linkCopied = true;
        StateHasChanged();

        // Reset "Copied!" text after 2 seconds. Tied to component lifetime via
        // _disposeCts so the continuation doesn't fire (and try to render) after dispose.
        var token = _disposeCts.Token;
        _ = Task.Delay(2000, token).ContinueWith(t =>
        {
            if (t.IsCanceled) return;
            _linkCopied = false;
            InvokeAsync(StateHasChanged);
        }, System.Threading.Tasks.TaskScheduler.Default);
    }

    private async Task ExportDashboard()
    {
        if (_activeDashboard is null) return;

        // Create a clean export object without internal state
        var export = new
        {
            Version = 1,
            _activeDashboard.Name,
            _activeDashboard.Description,
            Widgets = _activeDashboard.Widgets.OrderBy(w => w.Order).Select(w => new
            {
                w.WidgetType,
                w.ColumnSize,
                w.RowSpan,
                w.Offset,
                w.Row,
                w.Order,
                w.Config
            })
        };

        var json = JsonConvert.SerializeObject(export, Formatting.Indented);
        var safeName = _activeDashboard.Name.Replace(" ", "-").ToLowerInvariant();
        await JsInterop.DownloadJson($"dashboard-{safeName}.json", json);
    }

    private async Task ImportDashboard()
    {
        var json = await JsInterop.ReadFileAsText(_importFileInput);
        if (string.IsNullOrWhiteSpace(json)) return;

        try
        {
            var imported = JObject.Parse(json);

            var name = imported["Name"]?.Value<string>() ?? "Imported Dashboard";
            var description = imported["Description"]?.Value<string>();
            var widgetsArray = imported["Widgets"] as JArray;

            var dashboard = new DashboardDefinition
            {
                Id = Guid.NewGuid().ToString(),
                Name = name,
                Description = description,
                Scope = _activeScope
            };

            if (widgetsArray is not null)
            {
                var order = 0;
                foreach (var w in widgetsArray)
                {
                    dashboard.Widgets.Add(new WidgetPlacement
                    {
                        Id = Guid.NewGuid().ToString(),
                        WidgetType = w["WidgetType"]?.Value<string>() ?? "",
                        ColumnSize = w["ColumnSize"]?.Value<int>() ?? 6,
                        RowSpan = w["RowSpan"]?.Value<int>() ?? 1,
                        // Preserve null (auto-flow). Coercing missing offsets to 0 would pin
                        // every imported widget to column 0 under the new nullable semantics.
                        Offset = w["Offset"]?.Value<int?>(),
                        Row = w["Row"]?.Value<int?>(),
                        Order = order++,
                        Config = w["Config"] as JObject
                    });
                }
            }

            await SaveDashboardToScope(dashboard, _activeScope);
            _activeDashboard = dashboard;
            // Imported dashboard is now persisted; clear the auto-default flag so the
            // "Auto" badge disappears and SaveDashboard() stops short-circuiting.
            _isCodeDefault = false;
            _allDashboards.Add(dashboard);
            await ResetGrid();
        }
        catch
        {
            // Invalid JSON — silently ignore
        }
    }

    private async Task EnterEditMode()
    {
        _editDirty = false;
        EditMode = true;
        await JsInterop.SetEditMode(true);
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!_gridInitialized && IsSetUp && _activeDashboard is not null)
        {
            _gridInitialized = true;
            // Reuse the cached _dotNetRef rather than creating a new (and never disposed)
            // DotNetObjectReference per ResetGrid call. JS-side callbacks don't care about
            // the generic type; matching InitGrid's <object> signature lets us cache one ref.
            _dotNetRef ??= DotNetObjectReference.Create<object>(this);
            await JsInterop.InitGrid(_gridContainer, _dotNetRef, EditMode);
        }
    }

    /// <summary>
    /// Destroys the current gridstack instance and marks it for re-initialization
    /// on the next render. Call this whenever the dashboard widgets change wholesale
    /// (reset, delete, switch, import, create).
    /// </summary>
    private async Task ResetGrid()
    {
        if (_gridInitialized)
        {
            await JsInterop.DestroyGrid();
            _gridInitialized = false;
        }
    }

    private async Task ExitEditMode()
    {
        EditMode = false;
        _widgetEditMode = false;
        _confirmDelete = false;
        await JsInterop.SetEditMode(false);

        // Only materialize and save if the user actually made changes
        if (_editDirty)
        {
            // Materialize code default on first real change so it gets persisted
            await MaterializeCodeDefault();
            // Clear AutoMaterialized so template upgrades don't overwrite user edits
            if (_activeDashboard is not null && _activeDashboard.AutoMaterialized)
            {
                _activeDashboard.AutoMaterialized = false;
            }
            await SaveDashboard();
        }
        _editDirty = false;
    }

    private async Task DeleteDashboard()
    {
        if (_activeDashboard is null) return;

        var dashboardId = _activeDashboard.Id;
        var scope = _activeScope;

        // Remove from the appropriate scope's collection
        switch (scope)
        {
            case DashboardScope.Store when !string.IsNullOrEmpty(StoreId):
            {
                var collection = await DashboardService.GetStoreDashboards(StoreId);
                collection.Dashboards.RemoveAll(d => d.Id == dashboardId);
                if (collection.ActiveDashboardId == dashboardId)
                    collection.ActiveDashboardId = null;
                await DashboardService.SaveStoreDashboards(StoreId, collection);
                break;
            }
            case DashboardScope.Server:
            {
                var collection = await DashboardService.GetServerDashboards();
                collection.Dashboards.RemoveAll(d => d.Id == dashboardId);
                if (collection.ActiveDashboardId == dashboardId)
                    collection.ActiveDashboardId = null;
                await DashboardService.SaveServerDashboards(collection);
                break;
            }
        }

        // Remove from local list
        _allDashboards.RemoveAll(d => d.Id == dashboardId);

        // Exit edit mode
        EditMode = false;
        _widgetEditMode = false;
        _confirmDelete = false;
        await ResetGrid();

        // Switch to another dashboard or fall back to default template
        var deleteResolveStoreId = string.IsNullOrEmpty(StoreId) ? null : StoreId;
        _activeDashboard = await DashboardService.ResolveActiveDashboard(deleteResolveStoreId, BuildTemplateContext(), _isAdmin);
        _activeScope = DetermineActiveScope(_activeDashboard);

        // Check if we fell back to a code-generated default
        _isCodeDefault = _activeDashboard is not null
                         && _allDashboards.All(d => d.Id != _activeDashboard.Id);

        if (_activeDashboard is not null && _allDashboards.All(d => d.Id != _activeDashboard.Id))
        {
            _allDashboards.Add(_activeDashboard);
        }
    }

    [JSInvokable]
    public async Task OnGridChanged(string changesJson)
    {
        if (_activeDashboard is null) return;

        var changes = JsonConvert.DeserializeObject<List<GridChange>>(changesJson);
        if (changes is null || changes.Count == 0) return;

        foreach (var change in changes)
        {
            var placement = _activeDashboard.Widgets.FirstOrDefault(w => w.Id == change.Id);
            if (placement is null) continue;
            // Persist the explicit column even when it's 0; nullable Offset
            // distinguishes "unset (auto-flow)" from "deliberately at column 0".
            placement.Offset = change.X;
            // Row is the authoritative gridstack y. Order is kept in sync for
            // backwards compatibility with pre-Row JSON and template ordering.
            placement.Row = change.Y;
            placement.Order = change.Y;
            placement.ColumnSize = change.W;
            placement.RowSpan = change.H;
        }

        await SaveDashboard();
        await InvokeAsync(StateHasChanged);
    }

    private class GridChange
    {
        [JsonProperty("id")] public string Id { get; set; } = "";
        [JsonProperty("x")] public int X { get; set; }
        [JsonProperty("y")] public int Y { get; set; }
        [JsonProperty("w")] public int W { get; set; }
        [JsonProperty("h")] public int H { get; set; }
    }

    private record struct WidgetPosition(WidgetPlacement Placement, int X, int Y, int W);

    /// <summary>
    /// Computes gridstack x/y positions for each widget. Widgets with explicit
    /// Row + Offset (the result of a prior drag-save cycle) are placed at exactly
    /// those coordinates so real GridStack arrangements with gaps or stacked
    /// widgets beside taller neighbours survive a save-reload cycle. Widgets
    /// without explicit positions (template-fresh) auto-flow via a packer that
    /// runs after the explicits, starting one row below the lowest explicit row.
    /// </summary>
    private List<WidgetPosition> ComputeGridPositions()
    {
        var result = new List<WidgetPosition>();
        if (_activeDashboard is null) return result;

        // Explicit (Row + Offset both set) — render at the persisted coordinates.
        var explicitlyPlaced = _activeDashboard.Widgets
            .Where(w => w.Row.HasValue && w.Offset.HasValue)
            .OrderBy(w => w.Row!.Value)
            .ThenBy(w => w.Offset!.Value)
            .ToList();

        foreach (var p in explicitlyPlaced)
        {
            result.Add(new WidgetPosition(p, p.Offset!.Value, p.Row!.Value, p.ColumnSize));
        }

        // Auto-flow — pack the rest after the lowest occupied row, in template Order.
        var autoFlow = _activeDashboard.Widgets
            .Where(w => !w.Row.HasValue || !w.Offset.HasValue)
            .OrderBy(w => w.Order)
            .ThenBy(w => w.Offset ?? int.MaxValue)
            .ToList();

        if (autoFlow.Count == 0) return result;

        var colCursor = 0;
        var row = explicitlyPlaced.Count > 0
            ? explicitlyPlaced.Max(p => p.Row!.Value + Math.Max(p.RowSpan, 1))
            : 0;
        var rowHeight = 0;

        foreach (var p in autoFlow)
        {
            var w = p.ColumnSize;
            var x = p.Offset ?? colCursor;

            if (x + w > 12)
            {
                row += Math.Max(rowHeight, 1);
                rowHeight = 0;
                x = 0;
            }

            result.Add(new WidgetPosition(p, x, row, w));
            colCursor = x + w;
            rowHeight = Math.Max(rowHeight, p.RowSpan);
        }

        return result;
    }

    private async Task AddWidget(WidgetDescriptor descriptor)
    {
        if (_activeDashboard is null) return;

        // Shift all existing widgets down by one
        foreach (var w in _activeDashboard.Widgets)
            w.Order++;

        var placement = new WidgetPlacement
        {
            WidgetType = descriptor.Type,
            ColumnSize = descriptor.DefaultColumnSize,
            RowSpan = descriptor.DefaultRowSpan,
            Order = 0
        };
        _activeDashboard.Widgets.Add(placement);

        if (descriptor.RequiresConfiguration)
        {
            // Don't save yet — open config panel and mark as pending
            _pendingConfiguration = true;
            _configuringPlacement = placement;
            _configuringDescriptor = descriptor;
        }
        else
        {
            await SaveDashboard();
        }

        await ResetGrid();
    }

    private async Task RemoveWidget(WidgetPlacement placement)
    {
        if (_activeDashboard is null) return;

        _activeDashboard.Widgets.Remove(placement);
        // Re-index order values in-place
        var ordered = _activeDashboard.Widgets.OrderBy(w => w.Order).ToList();
        for (int i = 0; i < ordered.Count; i++)
            ordered[i].Order = i;
        await SaveDashboard();
    }

    private async Task OnWidgetConfigChanged(WidgetPlacement placement, JObject config)
    {
        placement.Config = config;
        await SaveDashboard();
    }

    private async Task OnWidgetSizeChanged((int cols, int rows) size)
    {
        await SaveDashboard();
    }

    private void OnWidgetEditMode(bool editing)
    {
        _widgetEditMode = editing;
        InvokeAsync(StateHasChanged);
    }

    private void OpenConfigPanel(WidgetPlacement placement, WidgetDescriptor descriptor)
    {
        _configuringPlacement = placement;
        _configuringDescriptor = descriptor;
    }

    private async Task SaveWidgetConfig(JObject config)
    {
        if (_configuringPlacement is not null)
        {
            _configuringPlacement.Config = config;
            _pendingConfiguration = false;
            _configuringPlacement = null;
            _configuringDescriptor = null;
            await SaveDashboard();
        }
    }

    private async Task CloseConfigPanel()
    {
        if (_pendingConfiguration && _configuringPlacement is not null && _activeDashboard is not null)
        {
            // User cancelled config for a newly added widget — remove it
            _activeDashboard.Widgets.Remove(_configuringPlacement);
            var ordered = _activeDashboard.Widgets.OrderBy(w => w.Order).ToList();
            for (int i = 0; i < ordered.Count; i++)
                ordered[i].Order = i;
            _activeDashboard.Widgets = ordered;
        }
        _pendingConfiguration = false;
        _configuringPlacement = null;
        _configuringDescriptor = null;
        await Task.CompletedTask;
    }

    private async Task SwitchDashboard(DashboardDefinition dashboard)
    {
        _activeDashboard = dashboard;
        _activeScope = dashboard.Scope;
        await ResetGrid();

        // Persist the active selection in the relevant scope
        switch (_activeScope)
        {
            case DashboardScope.Store when !string.IsNullOrEmpty(StoreId):
                var storeCol = await DashboardService.GetStoreDashboards(StoreId);
                storeCol.ActiveDashboardId = dashboard.Id;
                await DashboardService.SaveStoreDashboards(StoreId, storeCol);
                break;
            case DashboardScope.Server:
                var serverCol = await DashboardService.GetServerDashboards();
                serverCol.ActiveDashboardId = dashboard.Id;
                await DashboardService.SaveServerDashboards(serverCol);
                break;
        }
    }

    private async Task OnDashboardNameChanged(ChangeEventArgs e)
    {
        if (_activeDashboard is null) return;
        var newName = e.Value?.ToString()?.Trim();
        if (!string.IsNullOrEmpty(newName))
        {
            _activeDashboard.Name = newName;
            await SaveDashboard();
        }
    }

    private async Task CreateNewDashboard(DashboardScope scope, bool copyFromCurrent)
    {
        var scopeLabel = scope switch
        {
            DashboardScope.Server => "Server",
            _ => "Store"
        };

        DashboardDefinition newDashboard;
        if (copyFromCurrent && _activeDashboard is not null)
        {
            newDashboard = DashboardService.CopyDashboard(_activeDashboard,
                $"{_activeDashboard.Name} ({scopeLabel} Copy)");
        }
        else
        {
            newDashboard = new DashboardDefinition
            {
                Name = $"{scopeLabel} Dashboard {_allDashboards.Count(d => d.Scope == scope) + 1}"
            };
        }
        newDashboard.Scope = scope;

        await SaveDashboardToScope(newDashboard, scope);

        _activeDashboard = newDashboard;
        _activeScope = scope;
        // Newly created dashboard is persisted, not a code default.
        _isCodeDefault = false;
        _allDashboards.Add(newDashboard);
        await ResetGrid();
    }

    /// <summary>
    /// If the active dashboard is a code-generated default, materializes it into a real
    /// persisted dashboard in its current scope. After this call, _isCodeDefault is false
    /// and subsequent saves go to storage normally.
    /// </summary>
    private async Task MaterializeCodeDefault()
    {
        if (!_isCodeDefault || _activeDashboard is null) return;

        // Persist into the dashboard's existing scope (Server/Store/User). Forcing Store
        // here would change the ownership and default-resolution semantics of an edited
        // personal or server default.
        var scope = _activeDashboard.Scope;
        _activeDashboard.AutoMaterialized = true;
        _isCodeDefault = false;

        await SaveDashboardToScope(_activeDashboard, scope);
    }

    private async Task SaveDashboard()
    {
        if (_activeDashboard is null) return;

        // Track that a change happened during this edit session
        if (EditMode) _editDirty = true;

        // Code-generated defaults are never auto-saved — they stay fresh.
        // They only get persisted when explicitly materialized via MaterializeCodeDefault().
        if (_isCodeDefault) return;

        await SaveDashboardToScope(_activeDashboard, _activeScope);
    }

    private async Task SaveDashboardToScope(DashboardDefinition dashboard, DashboardScope scope)
    {
        switch (scope)
        {
            case DashboardScope.Store when !string.IsNullOrEmpty(StoreId):
            {
                var collection = await DashboardService.GetStoreDashboards(StoreId);
                UpsertDashboard(collection, dashboard);
                await DashboardService.SaveStoreDashboards(StoreId, collection);
                break;
            }
            case DashboardScope.Server:
            {
                var collection = await DashboardService.GetServerDashboards();
                UpsertDashboard(collection, dashboard);
                await DashboardService.SaveServerDashboards(collection);
                break;
            }
        }
    }

    private static void UpsertDashboard(DashboardCollection collection, DashboardDefinition dashboard)
    {
        var existing = collection.Dashboards.FirstOrDefault(d => d.Id == dashboard.Id);
        if (existing is not null)
            collection.Dashboards.Remove(existing);
        collection.Dashboards.Add(dashboard);
        collection.ActiveDashboardId = dashboard.Id;
    }

    public async ValueTask DisposeAsync()
    {
        _disposeCts.Cancel();
        _disposeCts.Dispose();
        _dotNetRef?.Dispose();
        await JsInterop.DestroyGrid();
    }
}

@model BTCPayServer.Plugins.Dashboard.Models.Dashboard2ViewModel
@using BTCPayServer.Plugins.Dashboard
@using BTCPayServer.Abstractions.Contracts
@using BTCPayServer.Views.Stores
@using Microsoft.AspNetCore.Identity
@inject IScopeProvider ScopeProvider
@inject UserManager<BTCPayServer.Data.ApplicationUser> UserManager
@{
    ViewData["Title"] = "Dashboard";
    ViewData.SetActivePage(StoreNavPages.Dashboard);
    this.ViewData.SetBlazorAllowed(true);
}

@section PageHeadContent {
    <link rel="stylesheet" href="~/vendor/gridstack/gridstack.min.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/vendor/chartist/chartist.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/vendor/chartist/chartist-plugin-tooltip.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/dashboard.css" asp-append-version="true" />
}

@(await Html.RenderComponentAsync<DashboardPage>(RenderMode.ServerPrerendered, new
{
    StoreId = ScopeProvider.GetCurrentStoreId(),
    UserId = UserManager.GetUserId(User),
    DashboardId = Model.DashboardId,
    IsSetUp = Model.IsSetUp,
    WalletEnabled = Model.WalletEnabled,
    LightningEnabled = Model.LightningEnabled,
    LightningSupported = Model.LightningSupported,
    CryptoCode = Model.CryptoCode
}))

@section PageFootContent {
    <script src="~/vendor/gridstack/gridstack-all.js" asp-append-version="true"></script>
    <script src="~/vendor/chartist/chartist.min.js" asp-append-version="true"></script>
    <script src="~/vendor/chartist/chartist-plugin-tooltip.js" asp-append-version="true"></script>
    <script src="~/js/dashboard-interop.js" asp-append-version="true"></script>
}

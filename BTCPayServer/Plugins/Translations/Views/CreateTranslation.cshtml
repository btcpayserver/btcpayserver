@using BTCPayServer.Views.Server
@model CreateTranslationViewModel
@{
	ViewData.SetLayoutModel(new LayoutModel(nameof(ServerNavPages.Translations), StringLocalizer["Create a new translation"])
        .SetCategory(WellKnownCategories.Server));
    ViewData.SetBreadcrumbs([new(StringLocalizer["Translations"], Action: nameof(BTCPayServer.Plugins.Translations.Controllers.UITranslationController.ListTranslations))]);
}
<form method="post">
	<div class="sticky-header">
		<vc:title-header />
		<input id="page-primary" type="submit" value="Create" class="btn btn-primary" />
	</div>

	<div class="row">
		<div class="col-xl-8 col-xxl-constrain">
			<div class="form-group">
				<label asp-for="Name" class="form-label" text-translate="true"></label>
				<input asp-for="Name" class="form-control" />
				<span asp-validation-for="Name" class="text-danger"></span>
			</div>
            <div class="form-group">
				<label asp-for="Fallback" class="form-label" text-translate="true"></label>
				<select asp-for="Fallback" class="form-select w-auto" asp-items="@Model.TranslationsListItems"></select>
				<span asp-validation-for="Fallback" class="text-danger"></span>
				<div class="form-text" text-translate="true">If a translation isn’t available, it will be searched in the fallback.</div>
            </div>
		</div>
	</div>
</form>

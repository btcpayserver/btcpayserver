@using System.Collections.Generic
@using System.Linq
@using System.Text.Json
@model ManagePluginsShellViewModel
@{
    Layout = "_Layout";
    ViewData.SetLayoutModel(new LayoutModel(nameof(ServerNavPages.Plugins), StringLocalizer["Plugin Directory"])
    {
        SubMenuItemId = "PluginDirectory"
    });

    var hiddenPluginIdentifiers = new HashSet<string>(StringComparer.OrdinalIgnoreCase);
    foreach (var plugin in Model.InstalledPlugins)
    {
        var identifier = plugin.Current?.Identifier;
        if (!string.IsNullOrEmpty(identifier))
        {
            hiddenPluginIdentifiers.Add(identifier);
        }
    }
    foreach (var plugin in Model.DisabledPlugins)
    {
        if (!string.IsNullOrEmpty(plugin.Identifier))
        {
            hiddenPluginIdentifiers.Add(plugin.Identifier);
        }
    }
    var hiddenPluginIdentifiersJson = JsonSerializer.Serialize(hiddenPluginIdentifiers.OrderBy(identifier => identifier, StringComparer.OrdinalIgnoreCase).ToArray());
}

<style>
    .plugin-manage-section--available {
        scroll-margin-top: 5rem;
    }

    .plugin-manage-frame {
        height: min(62vh, 680px);
        min-height: 520px;
        background: var(--btcpay-body-bg, #fff);
    }

    .plugin-manage-offcanvas {
        --bs-offcanvas-width: min(380px, 92vw);
    }

    #selected-plugin-panel,
    .plugin-manage-panel,
    .plugin-manage-panel-body,
    .plugin-manage-panel-details-section,
    .plugin-manage-panel-details {
        min-height: 0;
    }

    @@media (max-width: 991.98px) {
        .plugin-manage-frame {
            height: min(60vh, 600px);
            min-height: 460px;
        }

        .plugin-manage-offcanvas {
            --bs-offcanvas-width: min(100vw, 420px);
        }
    }
</style>

<partial name="_StatusMessage" />

@if (Model.PendingActions.Any())
{
    <div class="alert alert-info mb-4 d-flex align-items-center justify-content-between">
        <span text-translate="true">You need to restart BTCPay Server in order to update your active plugins.</span>
        <form method="post" asp-action="Maintenance" class="mt-2">
            <button type="submit" name="command" value="soft-restart" class="btn btn-info" text-translate="true">Restart now</button>
        </form>
    </div>
}

<div class="alert alert-warning alert-dismissible mb-4" role="alert">
    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="@StringLocalizer["Close"]">
        <vc:icon symbol="close" />
    </button>
    <h5 class="alert-heading" text-translate="true">Important notice about plugins</h5>
    <p class="mb-0">
        <span text-translate="true">Plugins are developed by third parties. They need to be updated and maintained regularly in addition to BTCPay Server. Use plugins at your own risk.</span>
        <a href="#warning-details" data-bs-toggle="collapse" class="alert-link" text-translate="true">Read more</a>
    </p>
    <div class="collapse" id="warning-details">
        <p class="my-3"><strong text-translate="true">Use at Your Own Risk:</strong> <span text-translate="true">Plugins in this store are developed by independent third parties. These plugins have not undergone review by the BTCPay Server team.</span></p>
        <p class="mb-3"><strong text-translate="true">Disclaimer of Responsibility:</strong> <span text-translate="true">BTCPay Server contributors or Foundation are not liable for any harm, loss, or damage resulting from the installation or use of the plugins. Users assume full responsibility for their installation, use, familiarity with licensing and terms of service and maintenance.</span></p>
        <p class="mb-3"><strong text-translate="true">No Official Endorsement:</strong> <span text-translate="true">Inclusion in the list of BTCPay Server plugins does not constitute an endorsement or guarantee of quality, safety, or compatibility.</span></p>
        <p class="mb-3"><strong text-translate="true">Due Diligence Advised:</strong> <span text-translate="true">We recommend users exercise caution and conduct their own research or consult the community before installing any plugin.</span></p>
        <p class="mb-0"><strong text-translate="true">Feedback and Reporting:</strong> <span text-translate="true">Should you experience issues with a plugin, please provide feedback or report concerns directly to the respective plugin developers.</span></p>
    </div>
</div>

<section id="available-plugins-section" class="m-0 plugin-manage-section--available">
    <div class="mb-4">
        <h3 class="mb-2" text-translate="true">Available Plugins</h3>
        <p class="text-muted mb-0" text-translate="true">Browse the public plugin directory here and install new plugins.</p>
    </div>

    <div id="plugins-embed-error-alert" class="alert alert-warning d-none mb-4" role="alert">
        <span text-translate="true">BTCPay Server could not load the plugin directory.</span>
    </div>
    <div id="plugins-embed-shell"
         class="pb-5"
         data-origin="@Model.DirectoryOrigin"
         data-iframe-url="@Model.DirectoryIframeUrl"
         data-panel-url="@Model.PanelUrl"
         data-selected-identifier="@Model.SelectedPluginIdentifier"
         data-selected-slug="@Model.SelectedPluginSlug"
         data-panel-error-message="@StringLocalizer["BTCPay Server could not load the plugin panel."]">
        <script type="application/json" id="plugins-embed-hidden-plugin-identifiers">@Html.Raw(hiddenPluginIdentifiersJson)</script>
        <iframe id="plugins-directory-iframe"
                title="@StringLocalizer["Plugin directory"]"
                class="plugin-manage-frame d-block w-100 border-0"
                sandbox="allow-same-origin allow-scripts allow-forms allow-popups"></iframe>
    </div>
    <div class="offcanvas offcanvas-end shadow plugin-manage-offcanvas"
         tabindex="-1"
         id="selected-plugin-offcanvas"
         data-bs-backdrop="false"
         data-bs-scroll="true"
         aria-labelledby="selected-plugin-offcanvas-label">
        <div class="offcanvas-header justify-content-end px-3 pt-3 pb-0">
            <h5 class="offcanvas-title visually-hidden" id="selected-plugin-offcanvas-label" text-translate="true">Manage plugin</h5>
            <button type="button" class="btn-close" data-bs-dismiss="offcanvas" aria-label="@StringLocalizer["Close"]"></button>
        </div>
        <div class="offcanvas-body d-flex flex-column overflow-hidden px-4 pt-0 pb-4">
            <div id="selected-plugin-panel" class="d-flex flex-grow-1">
                <partial name="_SelectedPluginPanel" model="Model.SelectedPluginPanel" />
            </div>
        </div>
    </div>
    <script src="~/js/server/plugins-embed.js" asp-append-version="true"></script>
</section>

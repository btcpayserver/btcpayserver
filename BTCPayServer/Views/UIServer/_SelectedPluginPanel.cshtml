@using System.Linq
@model PluginSelectedPanelViewModel
@{
    var pageRouteValues = new Dictionary<string, string>
    {
        ["returnTo"] = "directory"
    };
    var hasAvailableUpdate = Model.InstalledVersion is not null &&
                             Model.BestAvailableVersion is not null &&
                             Model.BestAvailableVersion.CompareTo(Model.InstalledVersion) > 0;
    string stateLabel = null;
    string stateDescription = null;
    var stateAlertClass = "alert-success";
    if (!string.IsNullOrEmpty(Model.PendingAction))
    {
        var pendingVersionSuffix = Model.PendingVersion is null ? string.Empty : $" {Model.PendingVersion}";
        stateLabel = StringLocalizer["Pending action"].Value;
        stateDescription = StringLocalizer["BTCPay Server has queued {0}{1} for this plugin.", Model.PendingAction, pendingVersionSuffix].Value;
        stateAlertClass = "alert-info";
    }
    else if (Model.DisabledVersion is not null)
    {
        stateLabel = StringLocalizer["Disabled"].Value;
        stateDescription = StringLocalizer["Version {0} is disabled on this server.", Model.DisabledVersion].Value;
        stateAlertClass = "alert-warning";
    }
    else if (Model.InstalledVersion is not null)
    {
        stateLabel = StringLocalizer["Installed"].Value;
        stateDescription = hasAvailableUpdate
            ? StringLocalizer["Version {0} is available. Manage updates from Installed Plugins.", Model.BestAvailableVersion].Value
            : StringLocalizer["This plugin is already installed on the server."].Value;
    }
    else if (Model.Plugin is not null && !Model.Plugin.DependenciesMet)
    {
        stateDescription = StringLocalizer["Dependencies are not met yet, so BTCPay Server will schedule the install."].Value;
        stateAlertClass = "alert-warning";
    }
    var stateClass = Model.DisabledVersion is not null
        ? "bg-danger"
        : Model.InstalledVersion is not null
            ? "bg-success"
            : "bg-secondary";
    var showState = !string.IsNullOrEmpty(stateLabel);
    var showEmbeddedDetails = !string.IsNullOrEmpty(Model.EmbeddedDetailsUrl);
    var showFacts = Model.InstalledVersion is not null ||
                    Model.DisabledVersion is not null ||
                    (!showEmbeddedDetails && Model.BestAvailableVersion is not null) ||
                    !string.IsNullOrEmpty(Model.PendingAction);
    var embedInstallAction = showEmbeddedDetails
        ? Model.Actions.FirstOrDefault(action => action.FormAction == "InstallPlugin" && !action.Disabled)
        : null;
    var allowPendingInstallVersionChange = showEmbeddedDetails &&
                                           embedInstallAction is null &&
                                           Model.InstalledVersion is null &&
                                           Model.DisabledVersion is null &&
                                           string.Equals(Model.PendingAction, "install", System.StringComparison.OrdinalIgnoreCase);
    var visibleActions = Model.Actions
        .Where(action => action != embedInstallAction)
        .ToList();
    if (!string.IsNullOrEmpty(Model.SelectedSlug))
        pageRouteValues["selectedSlug"] = Model.SelectedSlug;
}

@if (!Model.HasSelection)
{
    <div class="py-3 text-muted">
        <p class="mb-0" text-translate="true">Select a plugin in the directory to inspect the BTCPay Server state, compatibility checks, and available actions.</p>
    </div>
}
else
{
    <div class="plugin-manage-panel d-flex flex-column flex-grow-1 gap-3">
        @if (!showEmbeddedDetails)
        {
            <div class="d-flex flex-column gap-2 pb-3 border-bottom">
                @if (showState)
                {
                    <span class="badge align-self-start @stateClass">@stateLabel</span>
                }
                <h3 class="h4 lh-1 mb-0" data-bs-toggle="tooltip" title="@Model.Plugin.Identifier">@Model.Plugin.Name</h3>
                <div class="text-muted font-monospace small text-break">@Model.Plugin.Identifier</div>
                @if (!string.IsNullOrEmpty(Model.Plugin.Author))
                {
                    <div class="text-muted">
                        <span text-translate="true">by</span>
                        @if (!string.IsNullOrEmpty(Model.Plugin.AuthorLink))
                        {
                            <a href="@Model.Plugin.AuthorLink" rel="noreferrer noopener" target="_blank">@Model.Plugin.Author</a>
                        }
                        else
                        {
                            <span>@Model.Plugin.Author</span>
                        }
                    </div>
                }
            </div>
        }

        <div class="plugin-manage-panel-body d-flex flex-column flex-grow-1 gap-3 overflow-hidden">
            @if (!showEmbeddedDetails && !string.IsNullOrEmpty(stateDescription))
            {
                <p class="alert @stateAlertClass mb-0 py-2 px-3">@stateDescription</p>
            }

            @if (!showEmbeddedDetails)
            {
                <p class="mb-0 lh-base">@Model.Plugin.Description</p>
            }

            @if (showFacts)
            {
                <div class="border-top border-bottom">
                    @if (Model.InstalledVersion is not null)
                    {
                        <div class="d-flex align-items-baseline justify-content-between gap-3 py-2">
                            <span class="text-muted small fw-semibold text-uppercase" text-translate="true">Installed version</span>
                            <span class="text-end fw-semibold">@Model.InstalledVersion</span>
                        </div>
                    }
                    @if (Model.DisabledVersion is not null)
                    {
                        <div class="d-flex align-items-baseline justify-content-between gap-3 py-2">
                            <span class="text-muted small fw-semibold text-uppercase" text-translate="true">Disabled version</span>
                            <span class="text-end fw-semibold">@Model.DisabledVersion</span>
                        </div>
                    }
                    @if (!showEmbeddedDetails && Model.BestAvailableVersion is not null)
                    {
                        <div class="d-flex align-items-baseline justify-content-between gap-3 py-2">
                            <span class="text-muted small fw-semibold text-uppercase" text-translate="true">Version</span>
                            <span class="text-end fw-semibold">@Model.BestAvailableVersion</span>
                        </div>
                    }
                    @if (!string.IsNullOrEmpty(Model.PendingAction))
                    {
                        <div class="d-flex align-items-baseline justify-content-between gap-3 py-2">
                            <span class="text-muted small fw-semibold text-uppercase" text-translate="true">Pending action</span>
                            <span class="text-end fw-semibold">
                                @Model.PendingAction
                                @if (Model.PendingVersion is not null)
                                {
                                    <span>@Model.PendingVersion</span>
                                }
                            </span>
                        </div>
                    }
                </div>
            }

            @if (!showEmbeddedDetails && Model.Plugin.Dependencies.Any())
            {
                <section class="d-flex flex-column gap-2">
                    <h5 class="text-muted small fw-semibold text-uppercase mb-0" text-translate="true">Dependencies</h5>
                    <div class="d-grid gap-2">
                        @foreach (var dependency in Model.Plugin.Dependencies)
                        {
                            <div class="d-flex align-items-center gap-2 p-0">
                                <span class="flex-grow-1">@dependency.Display</span>
                                @if (!dependency.IsMet)
                                {
                                    <span title="@StringLocalizer["Dependency not met."]" data-bs-toggle="tooltip" class="text-danger">
                                        <vc:icon symbol="warning" />
                                    </span>
                                }
                            </div>
                        }
                    </div>
                </section>
            }

            @if (showEmbeddedDetails)
            {
                <section class="plugin-manage-panel-details-section d-flex flex-column flex-grow-1 gap-2 pt-1">
                    <iframe class="plugin-manage-panel-details d-block flex-grow-1 w-100 border-0" title="@StringLocalizer["{0} details", Model.Plugin.Name]" src="@Model.EmbeddedDetailsUrl" sandbox="allow-same-origin allow-scripts allow-forms allow-popups"></iframe>
                </section>
            }
        </div>

        @if (visibleActions.Count > 0)
        {
            <div class="d-grid gap-2 pt-3 border-top">
            @foreach (var action in visibleActions)
            {
                if (action.Disabled || string.IsNullOrEmpty(action.FormAction))
                {
                    <button type="button" class="@action.CssClass w-100" disabled title="@(string.IsNullOrEmpty(action.Tooltip) ? null : StringLocalizer[action.Tooltip].Value)">@StringLocalizer[action.Label]</button>
                }
                else
                {
                    <form method="post"
                          asp-action="@action.FormAction"
                          asp-all-route-data="pageRouteValues"
                          class="d-grid">
                        <input type="hidden" name="plugin" value="@action.Plugin" />
                        @if (!string.IsNullOrEmpty(action.Version))
                        {
                            <input type="hidden" name="version" value="@action.Version" />
                        }
                        <button type="submit" class="@action.CssClass w-100" title="@(string.IsNullOrEmpty(action.Tooltip) ? null : StringLocalizer[action.Tooltip].Value)">@StringLocalizer[action.Label]</button>
                    </form>
                }
            }
            </div>
        }
        @if (embedInstallAction is not null)
        {
            <form method="post"
                  asp-action="@embedInstallAction.FormAction"
                  asp-all-route-data="pageRouteValues"
                  class="d-none"
                  data-plugin-install-form="true"
                  data-selected-slug="@Model.SelectedSlug"
                  data-plugin-name="@Model.Plugin.Name">
                <input type="hidden" name="plugin" value="@embedInstallAction.Plugin" />
                @if (!string.IsNullOrEmpty(embedInstallAction.Version))
                {
                    <input type="hidden" name="version" value="@embedInstallAction.Version" />
                }
            </form>
        }
        else if (allowPendingInstallVersionChange)
        {
            <form method="post"
                  asp-action="InstallPlugin"
                  asp-all-route-data="pageRouteValues"
                  class="d-none"
                  data-plugin-install-form="true"
                  data-selected-slug="@Model.SelectedSlug"
                  data-plugin-name="@Model.Plugin.Name"
                  data-pending-install="true"
                  data-pending-install-version="@Model.PendingVersion">
                <input type="hidden" name="plugin" value="@Model.SelectedIdentifier" />
                <input type="hidden" name="version" />
            </form>
        }
    </div>
}

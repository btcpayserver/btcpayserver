@model AddEditCustomerViewModel

@{
    ViewData.SetActivePage(StoreNavPages.Customers, StringLocalizer["Add customer"]);
    string storeId = (string)this.Context.GetRouteValue("storeId");
}

<form method="post">
    <div class="sticky-header">
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb">
                <li class="breadcrumb-item">
                    <a asp-action="ListCustomers" asp-route-storeId="@storeId" text-translate="true">Customers</a>
                </li>
                <li class="breadcrumb-item active" aria-current="page">@ViewData["Title"]</li>
            </ol>
            <h2>@ViewData["Title"]</h2>
        </nav>
        <input id="page-primary" type="submit" value="Create" class="btn btn-primary" />
    </div>
    <partial name="_StatusMessage" />
    <div class="row">
        <div class="col-xl-8 col-xxl-constrain">
            <div class="form-group">
                <label asp-for="Data.Name" class="form-label"></label>
                <input asp-for="Data.Name" class="form-control" />
                <span asp-validation-for="Data.Name" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Email" class="form-label"></label>
                <input asp-for="Email" class="form-control" />
                <span asp-validation-for="Email" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Data.ExternalRef" class="form-label"></label>
                <input asp-for="Data.ExternalRef" class="form-control" />
                <span asp-validation-for="Data.ExternalRef" class="text-danger"></span>
            </div>
        </div>
    </div>
</form>

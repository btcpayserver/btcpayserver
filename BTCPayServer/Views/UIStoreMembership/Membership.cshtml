@using BTCPayServer.Client
@using BTCPayServer.Controllers
@using BTCPayServer.Services
@model MembershipViewModel
@inject DisplayFormatter DisplayFormatter

@{
    ViewData.SetActivePage(StoreNavPages.Membership, StringLocalizer["Membership"]);
    string storeId = (string)this.Context.GetRouteValue("storeId");
}

@section PageHeadContent {

    <style>
        .metric-value {
            font-size: 2rem;
            font-weight: 600;
            color: #212529;
            margin: 0.5rem 0;
        }

        .metric-label {
            color: #6c757d;
            font-size: 0.9rem;
            font-weight: 500;
        }

        .card h6 {
            font-weight: var(--btcpay-font-weight-semibold);
            color: var(--btcpay-body-text-muted);
        }
    </style>

}

<div class="sticky-header">
    <h2>@ViewData["Title"]</h2>
</div>

<partial name="_StatusMessage" />

<div class="container-fluid px-4 py-4">
    <!-- Metrics Cards -->
    <div class="row mb-4">
        <div class="col-md-3">
            <div class="card">
                <div class="card-body">
                    <h6>Total Revenue</h6>
                    <div class="balance d-flex align-items-baseline gap-1">
                        <h4 class="d-inline-block me-1" data-balance="0" data-sensitive="">@DisplayFormatter.Currency(Model.Stats.TotalRevenue, Model.Currency, DisplayFormatter.CurrencyFormat.None)</h4>
                        <span class="text-secondary fw-semibold currency">@Model.Currency</span>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card">
                <div class="card-body">
                    <h6>Active Members</h6>
                    <h4>@Model.Stats.ActiveMembersCount</h4>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card">
                <div class="card-body">
                    <h6>Active Subscriptions</h6>
                    <h4>@Model.Stats.ActiveSubscriptionsCount</h4>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card">
                <div class="card-body">
                    <h6>Pending Payments</h6>
                    <h4>2</h4>
                </div>
            </div>
        </div>
    </div>

    <!-- Navigation Tabs -->
    <ul id="SectionNav" class="nav mb-4">
        <a class="nav-link @(Model.Section == MembershipSection.Members ? "active" : "")" asp-action="Membership"
           asp-route-section="@MembershipSection.Members">Members & Payments</a>
        <a class="nav-link @(Model.Section == MembershipSection.Plans ? "active" : "")" asp-action="Membership" asp-route-section="@MembershipSection.Plans">Subscription
            Plans</a>
        <a class="nav-link @(Model.Section == MembershipSection.Emails ? "active" : "")" asp-action="Membership" asp-route-section="@MembershipSection.Emails">Notifications
            & Alerts</a>
    </ul>

    @if (Model.Section == MembershipSection.Plans)
    {
        <div class="d-flex justify-content-between align-items-center">
            <h4>Subscription Plans</h4>
            <a id="page-primary" permission="@Policies.CanModifyMembership" asp-route-storeId="@storeId" asp-action="AddMembershipPlan" class="btn btn-primary"
               role="button">
                Add Plan
            </a>
        </div>

        <!-- Subscription Plans Table -->
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead>
                <tr>
                    <th text-translate="true">Plan</th>
                    <th text-translate="true">API ID</th>
                    <th text-translate="true">Price</th>
                    <th text-translate="true">Recurring</th>
                    <th text-translate="true">Grace Period</th>
                    <th text-translate="true">Status</th>
                    <th text-translate="true">Active Members</th>
                    <th text-translate="true">Actions</th>
                </tr>
                </thead>
                <tbody>
                @if (Model.Plans.Count != 0)
                {
                    foreach (var p in Model.Plans)
                    {
                        <tr>
                            <td class="fw-semibold">@p.Data.Name</td>
                            <td>
                                <vc:truncate-center text="@p.Data.Id" link="@Url.Action(nameof(UIStoreMembershipController.PlanCheckout), new{ planId = p.Data.Id })" classes="truncate-center-id" />
                            </td>
                            <td>@DisplayFormatter.Currency(@p.Data.Price, @p.Data.Currency, DisplayFormatter.CurrencyFormat.CodeAndSymbol)</td>
                            <td>@p.Data.RecurringType</td>
                            <td>@p.Data.GracePeriodDays days</td>
                            <td><span class="status-active">@p.Data.Status</span></td>
                            <td>@p.Data.MemberCount Members</td>
                            <td>
                                <button class="btn btn-outline-success btn-sm action-btn">Edit</button>
                                <button class="btn btn-outline-danger btn-sm action-btn">Remove</button>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="8" class="text-secondary" text-translate="true">There are no subscription plans.</td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    }
    else if (Model.Section == MembershipSection.Members)
    {
        <div class="d-flex justify-content-between align-items-center">
            <h4>Members</h4>
            <a id="page-primary" asp-route-storeId="@storeId" asp-action="AddCustomer" class="btn btn-primary" role="button">
                Add Member
            </a>
        </div>

        <!-- Subscription Plans Table -->
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead>
                <tr>
                    <th text-translate="true">User</th>
                    <th text-translate="true">Plan</th>
                    <th text-translate="true">Next Due</th>
                    <th text-translate="true">Status</th>
                    <th text-translate="true">Actions</th>
                </tr>
                </thead>
                <tbody>
                <tr>
                    <td class="fw-semibold">user1@example.com</td>
                    <td>Basic</td>
                    <td>2/14/2024</td>
                    <td><span class="status-active">Active</span></td>
                    <td>
                        <button class="btn btn-outline-success btn-sm action-btn">Edit</button>
                        <button class="btn btn-outline-danger btn-sm action-btn">Remove</button>
                    </td>
                </tr>
                <tr>
                    <td class="fw-semibold">user1@example.com</td>
                    <td>Basic</td>
                    <td>2/14/2024</td>
                    <td><span class="status-active">Active</span></td>
                    <td>
                        <button class="btn btn-outline-success btn-sm action-btn">Edit</button>
                        <button class="btn btn-outline-danger btn-sm action-btn">Remove</button>
                    </td>
                </tr>
                </tbody>
            </table>
        </div>
    }
</div>

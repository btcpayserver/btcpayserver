@inject BTCPayServer.Services.BTCPayServerEnvironment Env
@model PlanCheckoutViewModel

@{
    ViewData["Title"] = Model.Title;
    ViewData["StoreBranding"] = Model.StoreBranding;
    Layout = null;
    ViewData.SetBlazorAllowed(false);
    var items = Model.Data.GetAdditionalData<SubscriptionPlanData.BTCPayAdditionalData>().PlanItems ?? new();
}

<!DOCTYPE html>
<html lang="en" @(Env.IsDeveloping ? " data-devenv" : "") id="PlanCheckout-@Model.Id">
<head>
    <partial name="LayoutHead"/>
    <link href="~/vendor/font-awesome/css/font-awesome.min.css" asp-append-version="true" rel="stylesheet"/>

    <style>
        :root {
            --primary-color: #059669;
            --primary-hover: #047857;
            --text-muted: #6b7280;
            --border-color: #e5e7eb;
        }

        body {
            background-color: #f9fafb;
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
        }

        .checkout-container {
            max-width: 500px;
            margin: 2rem auto;
            background: white;
            border-radius: 12px;
            box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1);
            overflow: hidden;
        }

        .checkout-header {
            background: linear-gradient(135deg, var(--primary-color), #10b981);
            color: white;
            padding: 2rem;
            text-align: center;
        }

        .company-logo {
            width: 60px;
            height: 60px;
            background: white;
            border-radius: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 1rem;
            font-size: 24px;
            color: var(--primary-color);
            font-weight: bold;
        }

        .checkout-body {
            padding: 2rem;
        }

        .subscription-details {
            background: #f8fafc;
            border-radius: 8px;
            padding: 1.5rem;
            margin-bottom: 2rem;
            border-left: 4px solid var(--primary-color);
        }

        .price-display {
            font-size: 2rem;
            font-weight: 700;
            color: var(--primary-color);
            margin-bottom: 0.5rem;
        }

        .billing-cycle {
            color: var(--text-muted);
            font-size: 0.9rem;
        }

        .feature-list {
            list-style: none;
            padding: 0;
            margin: 1rem 0 0 0;
        }

        .feature-list li {
            padding: 0.5rem 0;
            display: flex;
            align-items: center;
            color: #374151;
        }

        .feature-list li i {
            color: var(--primary-color);
            margin-right: 0.75rem;
            width: 16px;
        }

        .form-control:focus {
            border-color: var(--primary-color);
            box-shadow: 0 0 0 0.2rem rgba(5, 150, 105, 0.25);
        }

        .btn-checkout {
            background: var(--primary-color);
            border: none;
            padding: 0.875rem 2rem;
            font-weight: 600;
            border-radius: 8px;
            transition: all 0.2s;
        }

        .btn-checkout:hover {
            background: var(--primary-hover);
            transform: translateY(-1px);
        }

        .btn-checkout:disabled {
            background: #d1d5db;
            transform: none;
        }

        .security-notice {
            background: #f0fdf4;
            border: 1px solid #bbf7d0;
            border-radius: 6px;
            padding: 1rem;
            margin-top: 1.5rem;
            text-align: center;
            font-size: 0.875rem;
            color: #166534;
        }

        .payment-methods {
            display: flex;
            justify-content: center;
            gap: 1rem;
            margin-top: 1rem;
            opacity: 0.7;
        }

        .payment-methods i {
            font-size: 1.5rem;
            color: var(--text-muted);
        }
    </style>
</head>
<body>
    <div class="container">
        <div class="checkout-container">
            <!-- Header -->
            <div class="checkout-header">
                <div class="company-logo">
                    <i class="fas fa fa-shield-alt"></i>
                </div>
                <h1 class="h4 mb-0">Complete Your Subscription</h1>
                <p class="mb-0 mt-2 opacity-90">SecurePayments Pro</p>
            </div>

            <!-- Checkout Body -->
            <div class="checkout-body">
                <!-- Subscription Details -->
                <div class="subscription-details">
                    <h2 class="h5 mb-3">@Model.Data.Name</h2>
                    <div class="price-display">$29.99</div>
                    <div class="billing-cycle">per month, billed monthly</div>

                    @if (!string.IsNullOrWhiteSpace((Model.Data.Description)))
                    {
                        <p class ="text-muted mt-3 mb-3" >@Model.Data.Description</p>
                    }

                    <ul class="feature-list">
                        @foreach (var item in items)
                        {
                            <li><i class="fas fa fa-check"></i>@item.ShortDescription</li>
                        }
                    </ul>
                </div>

                <!-- Email Form -->
                <form id="checkoutForm">
                    <div class="mb-4">
                        <label for="email" class="form-label fw-semibold">Email Address</label>
                        <input
                            type="email"
                            class="form-control form-control-lg"
                            id="email"
                            placeholder="Enter your email address"
                            required
                        >
                        <div class="form-text">We'll send your receipt and account details to this email.</div>
                    </div>

                    <button type="submit" class="btn btn-checkout btn-lg w-100" id="proceedBtn" disabled>
                        <i class="fas fa fa-lock me-2"></i>
                        Proceed to Secure Checkout
                    </button>
                </form>

                <!-- Security Notice -->
                <div class="security-notice">
                    <i class="fas fa fa-shield-alt me-2"></i>
                    <strong>Secure Checkout:</strong> Your payment information is encrypted and protected by industry-standard SSL security.
                </div>

                <!-- Payment Methods -->
                <div class="payment-methods">
                    <i class="fab fa fa-cc-visa"></i>
                    <i class="fab fa fa-cc-mastercard"></i>
                    <i class="fab fa fa-cc-amex"></i>
                    <i class="fab fa fa-cc-paypal"></i>
                </div>
            </div>
        </div>
    </div>

    <script>
        // Email validation and button state management
        const emailInput = document.getElementById('email');
        const proceedBtn = document.getElementById('proceedBtn');
        const checkoutForm = document.getElementById('checkoutForm');

        emailInput.addEventListener('input', function() {
            const isValid = this.checkValidity() && this.value.length > 0;
            proceedBtn.disabled = !isValid;
        });

        checkoutForm.addEventListener('submit', function(e) {
            e.preventDefault();
            const email = emailInput.value;

            if (email && emailInput.checkValidity()) {
                // Here you would typically redirect to your payment processor
                // For demo purposes, we'll show an alert
                alert(`Proceeding to checkout for: ${email}`);

                // Example redirect to payment processor:
                // window.location.href = `/payment?email=${encodeURIComponent(email)}&plan=professional`;
            }
        });
    </script>
</body>
</html>

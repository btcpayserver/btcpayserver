@using BTCPayServer.Client
@using BTCPayServer.Controllers
@using BTCPayServer.Services
@using BTCPayServer.Abstractions
@model SubscriptionsViewModel
@inject DisplayFormatter DisplayFormatter

@{
    ViewData.SetActivePage(StoreNavPages.Subscriptions, StringLocalizer["Subscriptions"]);
    string storeId = (string)this.Context.GetRouteValue("storeId");
    string offeringId = (string)this.Context.GetRouteValue("offeringId");
}

@section PageHeadContent {

    <style>
        .card h6 {
            font-weight: var(--btcpay-font-weight-semibold);
            color: var(--btcpay-body-text-muted);
        }
    </style>

}

<div class="sticky-header">
    <h2>@ViewData["Title"]</h2>
</div>

<partial name="_StatusMessage" />

<div class="container-fluid px-4 py-4">
    <!-- Metrics Cards -->
    <div class="row mb-4">
        <div class="col-md-3">
            <div class="card">
                <div class="card-body">
                    <h6>Total Revenue</h6>
                    <div class="balance d-flex align-items-baseline gap-1">
                        <h4 class="d-inline-block me-1" data-balance="0" data-sensitive=""></h4>
                        <span class="text-secondary fw-semibold currency">@Model.Currency</span>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card">
                <div class="card-body">
                    <h6>Active Members</h6>
                    <h4>0</h4>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card">
                <div class="card-body">
                    <h6>Active Subscriptions</h6>
                    <h4>0</h4>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card">
                <div class="card-body">
                    <h6>Pending Payments</h6>
                    <h4>2</h4>
                </div>
            </div>
        </div>
    </div>

    <!-- Navigation Tabs -->
    <ul id="SectionNav" class="nav mb-4">
        <a class="nav-link @(Model.Section == SubscriptionSection.Subscribers ? "active" : "")" asp-action="Membership"
           asp-route-section="@SubscriptionSection.Subscribers">Members & Payments</a>
        <a class="nav-link @(Model.Section == SubscriptionSection.Plans ? "active" : "")" asp-action="Membership" asp-route-section="@SubscriptionSection.Plans">Subscription
            Plans</a>
        <a class="nav-link @(Model.Section == SubscriptionSection.Emails ? "active" : "")" asp-action="Membership" asp-route-section="@SubscriptionSection.Emails">Notifications
            & Alerts</a>
    </ul>

    @if (Model.Section == SubscriptionSection.Plans)
    {
        <div class="d-flex justify-content-between align-items-center">
            <h4>Subscription Plans</h4>
            <a id="page-primary" permission="@Policies.CanModifyMembership" asp-route-storeId="@storeId" asp-route-offeringId="@offeringId" asp-action="AddPlan" class="btn btn-primary"
               role="button">
                Add Plan
            </a>
        </div>

        <!-- Subscription Plans Table -->
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead>
                <tr>
                    <th text-translate="true">Plan</th>
                    <th text-translate="true">API ID</th>
                    <th text-translate="true">Price</th>
                    <th text-translate="true">Recurring</th>
                    <th text-translate="true">Grace Period</th>
                    <th text-translate="true">Status</th>
                    <th text-translate="true">Active Members</th>
                    <th text-translate="true">Actions</th>
                </tr>
                </thead>
                <tbody>
                @if (Model.Plans.Count != 0)
                {
                    foreach (var p in Model.Plans)
                    {
                        <tr>
                            <td class="fw-semibold">@p.Data.Name</td>
                            <td>
                                <vc:truncate-center text="@p.Data.Id" link="@Url.Action(nameof(UIStoreSubscriptionsController.PlanCheckout), new{ planId = p.Data.Id })" classes="truncate-center-id" />
                            </td>
                            <td>@DisplayFormatter.Currency(@p.Data.Price, @p.Data.Currency, DisplayFormatter.CurrencyFormat.CodeAndSymbol)</td>
                            <td>@p.Data.RecurringType</td>
                            <td>@p.Data.GracePeriodDays days</td>
                            <td><span class="status-active">@p.Data.Status</span></td>
                            <td>@p.Data.MemberCount Members</td>
                            <td>
                                <button class="btn btn-outline-success btn-sm action-btn">Edit</button>
                                <button class="btn btn-outline-danger btn-sm action-btn">Remove</button>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="8" class="text-secondary" text-translate="true">There are no subscription plans.</td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    }
    else if (Model.Section == SubscriptionSection.Subscribers)
    {
        <div class="d-flex justify-content-between align-items-center">
            <h4>Subscribers</h4>
            <a id="page-primary" asp-route-storeId="@storeId" asp-action="AddCustomer" class="btn btn-primary" role="button">
                Add subscriber
            </a>
        </div>

        <!-- Subscription Plans Table -->
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead>
                <tr>
                    <th text-translate="true">User</th>
                    <th text-translate="true">Plan</th>
                    <th text-translate="true">Next Due</th>
                    <th text-translate="true">Status</th>
                    <th text-translate="true">Actions</th>
                </tr>
                </thead>
                <tbody>
                @foreach(var subscriber in Model.Subscribers)
                {
                    <tr>
                        <td class="fw-semibold">@subscriber.Data.Customer.Email</td>
                        <td>@subscriber.Data.Plan.Name</td>
                        <td class="date-col">
                        @if (subscriber.Data.PeriodEnd is { } pe)
                        {
                            <span>@pe.ToBrowserDate()</span>
                        }
                        </td>
                        <td><span class="status-active">@subscriber.Data.Phase</span></td>
                        <td>
                            <button class="btn btn-outline-success btn-sm action-btn">Edit</button>
                            <button class="btn btn-outline-danger btn-sm action-btn">Remove</button>
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    }
</div>

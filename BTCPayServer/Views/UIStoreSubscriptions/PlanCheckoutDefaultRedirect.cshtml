@model PlanCheckoutDefaultRedirectViewModel
@{
    ViewData["Title"] = Model.Title;
    ViewData["StoreBranding"] = Model.StoreBranding;
    Layout = null;
    ViewData.SetBlazorAllowed(false);
}


<!DOCTYPE html>
<html lang="en"  id="PlanCheckout-@Model.Id">
<head>
    <partial name="LayoutHead" />
    <link href="~/vendor/font-awesome/css/font-awesome.min.css" asp-append-version="true" rel="stylesheet" />
    <link href="~/main/site.css" asp-append-version="true" rel="stylesheet" />

    <style>
        :root {
            --primary-color: #059669;
            --success-color: #10b981;
            --text-dark: #1f2937;
            --text-muted: #6b7280;
            --border-color: #e5e7eb;
        }

        body {
            background-color: var(--btcpay-body-bg-medium);
            color: var(--btcpay-body-text);
        }

        .success-container {
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 2rem 1rem;
        }

        .success-card {
            background: white;
            border-radius: 12px;
            box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1);
            padding: 3rem;
            text-align: center;
            max-width: 500px;
            width: 100%;
        }

        .success-icon {
            width: 80px;
            height: 80px;
            background: var(--success-color);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 2rem;
            animation: pulse 2s infinite;
        }

        @keyframes pulse {
            0% { transform: scale(1); }
            50% { transform: scale(1.05); }
            100% { transform: scale(1); }
        }

        .success-icon i {
            color: white;
            font-size: 2rem;
        }

        .success-title {
            color: var(--text-dark);
            font-size: 2rem;
            font-weight: 700;
            margin-bottom: 1rem;
        }

        .success-message {
            color: var(--text-muted);
            font-size: 1.1rem;
            margin-bottom: 2rem;
            line-height: 1.6;
        }

        .access-info {
            background: #f0fdf4;
            border: 1px solid #bbf7d0;
            border-radius: 8px;
            padding: 1.5rem;
            margin-bottom: 2rem;
        }

        .access-info h5 {
            color: var(--success-color);
            font-weight: 600;
            margin-bottom: 0.5rem;
        }

        .access-info p {
            color: var(--text-muted);
            margin: 0;
        }

        .btn-primary {
            background-color: var(--primary-color);
            border-color: var(--primary-color);
            padding: 0.75rem 2rem;
            font-weight: 600;
            border-radius: 8px;
            transition: all 0.3s ease;
        }

        .btn-primary:hover {
            background-color: #047857;
            border-color: #047857;
            transform: translateY(-1px);
        }

        .company-logo {
            width: 60px;
            height: 60px;
            background: var(--primary-color);
            border-radius: 8px;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 1rem;
        }

        .company-logo i {
            color: white;
            font-size: 1.5rem;
        }

        .footer-text {
            color: var(--text-muted);
            font-size: 0.9rem;
            margin-top: 2rem;
        }
    </style>
</head>
<body>
    <div class="success-container">
        <div class="success-card">
            <div class="company-logo">
                <i class="fas fa-code"></i>
            </div>

            <div class="success-icon">
                <i class="fas fa-check"></i>
            </div>

            <h1 class="success-title">Payment Successful!</h1>

            <p class="success-message">
                Thank you for your purchase! Your payment has been processed successfully and your subscription is now active.
            </p>

            <div class="access-info">
                <h5><i class="fas fa-unlock-alt me-2"></i>You Now Have Access</h5>
                <p>Your Professional Plan subscription is active. You can start using all premium features immediately.</p>
            </div>

            <div class="d-grid gap-2">
                <button type="button" class="btn btn-primary btn-lg" onclick="window.location.href='dashboard.html'">
                    <i class="fas fa-arrow-right me-2"></i>Access Your Dashboard
                </button>
            </div>

            <p class="footer-text">
                A confirmation email has been sent to your registered email address with your subscription details.
            </p>
        </div>
    </div>
</body>
</html>
